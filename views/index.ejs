<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NH DIGITAL SCHOOL | Future-Ready</title>
    
    <!-- Framework & Fonts -->
    <link href="https://cdn.jsdelivr.net" rel="stylesheet">
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --cyber-blue: #00f2ff;
            --cyber-deep: #0061ff;
            --dark-bg: #030712;
            --glass: rgba(255, 255, 255, 0.03);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #ffffff; /* Latar putih bersih sesuai foto referensi */
            color: #1f2937;
            overflow-x: hidden;
        }

        .mono { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--cyber-deep); letter-spacing: 1px; }

        /* --- NAVBAR GLASS --- */
        .navbar {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 18px 0;
        }
        .navbar-brand { font-weight: 800; color: #111827 !important; letter-spacing: -1px; }
        .nav-link { font-weight: 600; color: #4b5563 !important; margin: 0 12px; font-size: 0.95rem; }
        .btn-portal { background: #111827; color: white; border-radius: 12px; padding: 10px 24px; font-weight: 600; transition: 0.3s; }
        .btn-portal:hover { background: var(--cyber-deep); transform: translateY(-2px); }

        /* --- HERO SECTION --- */
        .hero {
            background: linear-gradient(135deg, #0061ff 0%, #60a5fa 100%);
            padding: 120px 0 180px 0;
            color: white;
            position: relative;
            clip-path: ellipse(150% 100% at 50% 0%); /* Efek lengkung bawah elegan */
        }

        /* Animasi Grid Cyber di Background */
        .hero::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), 
                              linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
            background-size: 50px 50px;
        }

        .hero h1 { font-weight: 800; font-size: 4rem; letter-spacing: -2px; line-height: 1.1; }
        .location-tag { font-size: 1.4rem; opacity: 0.9; font-weight: 400; }
        
        /* Modern Search Box */
        .search-wrapper {
            background: white;
            padding: 8px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            max-width: 650px;
            margin-top: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
        }
        .search-wrapper input { border: none; padding: 15px 25px; flex-grow: 1; outline: none; border-radius: 15px; font-size: 1.1rem; }
        .search-wrapper select { border: none; border-left: 1px solid #e5e7eb; padding: 0 20px; color: #6b7280; outline: none; background: transparent; }
        .search-wrapper button { background: #111827; color: white; border: none; padding: 15px 35px; border-radius: 15px; font-weight: 700; transition: 0.3s; }
        .search-wrapper button:hover { background: #000; letter-spacing: 1px; }

        /* Stats Bar */
        .stats-container { display: flex; gap: 50px; margin-top: 60px; }
        .stat-card h2 { font-weight: 800; margin-bottom: 0; font-size: 2.5rem; }
        .stat-card p { font-size: 0.85rem; opacity: 0.8; text-transform: uppercase; font-weight: 600; }

        /* Floating Card */
        .floating-cyber {
            background: white;
            padding: 25px;
            border-radius: 24px;
            box-shadow: 0 30px 60px -12px rgba(0,0,0,0.15);
            position: absolute;
            bottom: -60px;
            right: 10%;
            display: flex;
            align-items: center;
            gap: 20px;
            border: 1px solid rgba(255,255,255,0.3);
            transition: 0.5s;
        }
        .floating-cyber:hover { transform: translateY(-10px) scale(1.05); }

        /* --- ICON GRID SECTION --- */
        .features-grid { padding: 150px 0 80px 0; }
        .feature-item { text-align: center; transition: 0.4s; padding: 20px; }
        .icon-wrap {
            width: 90px; height: 90px;
            background: #f3f4f6;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2rem;
            color: #111827;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(0,0,0,0.03);
        }
        .feature-item:hover .icon-wrap {
            background: #111827;
            color: var(--cyber-blue);
            transform: translateY(-15px) rotate(10deg);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        .feature-item span { font-weight: 800; color: #1f2937; font-size: 1.1rem; }

    </style>
</head>
<body>

    <!-- NAV BAR -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <i class="bi bi-cpu-fill text-primary me-2 fs-3"></i> NH DIGITAL SCHOOL
            </a>
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Profil</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Direktori</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Publikasi</a></li>
                </ul>
            </div>
            <a href="mailto:<%= email %>" class="btn-portal text-decoration-none">Hubungi Kami <i class="bi bi-arrow-right ms-2"></i></a>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8" data-aos="fade-right">
                    <div class="mono mb-2">// STATUS: SECURE_CONNECTION_v22</div>
                    <div class="badge rounded-pill bg-white bg-opacity-25 px-3 py-2 mb-4">Selamat Datang di Portal Resmi</div>
                    <h1>School Nurul Hidayah</h1>
                    <p class="location-tag mt-2">Kabupaten Tasikmalaya, Jawa Barat</p>
                    
                    <div class="search-wrapper">
                        <input type="text" placeholder="Cari info sekolah..">
                        <select>
                            <option>Berita</option>
                            <option>Event</option>
                        </select>
                        <button><i class="bi bi-search me-2"></i> Pencarian</button>
                    </div>

                    <div class="stats-container">
                        <div class="stat-card">
                            <h2 class="mono">12</h2>
                            <p>Jumlah Guru</p>
                        </div>
                        <div class="stat-card">
                            <h2 class="mono">245</h2>
                            <p>Jumlah Siswa</p>
                        </div>
                        <div class="stat-card">
                            <h2 class="mono">08</h2>
                            <p>Komite Sekolah</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 text-center position-relative d-none d-lg-block" data-aos="zoom-in">
                    <!-- Floating Cyber Badge -->
                    <div class="floating-cyber">
                        <div class="bg-dark text-white rounded-circle p-3 d-flex align-items-center justify-content-center" style="width:60px; height:60px;">
                            <i class="bi bi-rocket-takeoff fs-4"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="fw-bold mb-0">Go Digital</h6>
                            <p class="small text-muted mb-0">Sekolahku Future-Ready</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- MENU GRID -->
    <section class="features-grid">
        <div class="container">
            <div class="row g-4">
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-bank"></i></div>
                        <span>Profil</span>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-diagram-3"></i></div>
                        <span>Struktur</span>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-people"></i></div>
                        <span>Komite</span>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-mortarboard"></i></div>
                        <span>Guru</span>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-person-badge"></i></div>
                        <span>Siswa</span>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-item">
                        <div class="icon-wrap"><i class="bi bi-broadcast"></i></div>
                        <span>Publikasi</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="text-center py-5 border-top bg-light">
        <p class="text-muted fw-bold mb-0">© 2026 <%= nama %> | Built by Solo AI</p>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://unpkg.com"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
    </script>
</body>
</html>
