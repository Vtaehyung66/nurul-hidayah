  <title>NURUL HIDAYAH – robotic cyber frame</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif;
    }

    body {
      min-height: 100vh;
      background: radial-gradient(circle at 20% 30%, #0b0f1c, #010101 90%);
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
      position: relative;
      overflow-x: hidden;
    }

    /* === background partikel bergerak (bulat saling menyambung + binary vibe) === */
    .cyber-particles {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .particle {
      position: absolute;
      width: 6px;
      height: 6px;
      background: rgba(0, 255, 200, 0.5);
      border-radius: 50%;
      box-shadow: 0 0 15px #00f7ff, 0 0 30px #2ad4ff;
      animation: floatParticle 18s infinite alternate ease-in-out;
    }

    .connector {
      position: absolute;
      height: 2px;
      background: linear-gradient(90deg, #00ffff80, #ff00d080, #00ffff80);
      opacity: 0.4;
      transform-origin: 0 0;
      pointer-events: none;
      border-radius: 2px;
      box-shadow: 0 0 12px cyan;
      animation: flicker 8s infinite;
    }

    @keyframes floatParticle {
      0% { transform: translate(0, 0) scale(1); opacity: 0.4; }
      100% { transform: translate(40px, -30px) scale(1.8); opacity: 0.9; }
    }

    @keyframes flicker {
      0% { opacity: 0.2; }
      50% { opacity: 0.7; }
      100% { opacity: 0.2; }
    }

    /* binary overlay (halus) */
    .binary-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: repeating-linear-gradient(45deg, 
        rgba(10, 255, 210, 0.02) 0px, 
        rgba(0, 0, 0, 0) 40px);
      pointer-events: none;
      z-index: 1;
    }

    /* ===== CARD UTAMA ===== */
    .document-card {
      max-width: 1200px;
      width: 100%;
      background: rgba(12, 20, 30, 0.65);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border: 2px solid #0affc0;
      box-shadow: 0 0 40px #00b8ff, inset 0 0 15px #4affb5;
      padding: 30px 25px;
      border-radius: 32px;
      position: relative;
      z-index: 10;
      transition: box-shadow 0.2s;
    }

    /* efek tekan binary 101010 */
    .document-card:active::after {
      content: "101010 101010 010101 011001 101010";
      position: absolute;
      bottom: 10px;
      right: 20px;
      font-size: 24px;
      font-weight: bold;
      color: #00ffc3;
      opacity: 0.25;
      white-space: pre;
      font-family: 'Courier New', monospace;
      pointer-events: none;
      animation: binaryFade 0.6s;
    }

    @keyframes binaryFade {
      0% { opacity: 0.7; transform: scale(1.2); }
      100% { opacity: 0; transform: scale(1); }
    }

    /* robotik bright frame untuk setiap bingkai */
    .robotic-frame {
      border: 2px solid #00f2fe;
      border-radius: 24px;
      box-shadow: 0 0 25px #0af, 0 0 60px #f0f, inset 0 0 10px cyan;
      background: rgba(0, 15, 25, 0.7);
      backdrop-filter: blur(3px);
      padding: 12px;
      transition: 0.2s;
    }

    .robotic-frame:hover {
      box-shadow: 0 0 40px #0ff, 0 0 90px #f0f, inset 0 0 20px yellow;
      border-color: #f0f;
    }

    /* TYPOGRAPHY MIRIP FOTO */
    .main-title {
      font-size: 3.5rem;
      font-weight: 800;
      text-align: center;
      color: #b5ffff;
