  <!-- partikel generator JS (lingkaran & garis saling sambung) -->
  <script>
    (function createParticlesAndConnections() {
      const container = document.getElementById('particles');
      const particleCount = 38;
      const particles = [];
      // buat partikel
      for (let i = 0; i < particleCount; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const x = Math.random() * 100;
        const y = Math.random() * 100;
        p.style.left = x + '%';
        p.style.top = y + '%';
        p.style.animationDelay = (i * 0.2) + 's';
        p.style.width = (Math.random() * 12 + 4) + 'px';
        p.style.height = p.style.width;
        container.appendChild(p);
        particles.push({ el: p, x, y });
      }

      // garis sambung antar partikel terdekat
      function drawConnections() {
        const threshold = 12; // % jarak sambung
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < threshold) {
              const line = document.createElement('div');
              line.className = 'connector';
              const x1 = particles[i].x, y1 = particles[i].y;
              const x2 = particles[j].x, y2 = particles[j].y;
              const length = Math.sqrt((x2-x1)**2 + (y2-y1)**2) * window.innerWidth / 100; // perkiraan
              const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;
              line.style.width = length + 'px';
              line.style.left = x1 + '%';
              line.style.top = y1 + '%';
              line.style.transform = `rotate(${angle}deg)`;
              line.style.backgroundColor = `hsl(${Math.random()*60 + 160}, 90%, 60%)`;
              container.appendChild(line);
            }
          }
        }
      }

      // refresh garis jika resize (sederhana)
      window.addEventListener('load', ()=>{
        drawConnections();
      });
      setTimeout(drawConnections, 100);
    })();
  </script>
  <!-- tambah efek tekan binary (selain sudah ada di css active) -->
  <script>
    document.querySelectorAll('.teacher-card, .document-card').forEach(el => {
      el.addEventListener('mousedown', (e) => {
        const bin = document.createElement('div');
        bin.innerText = '101010';
        bin.style.position = 'absolute';
        bin.style.left = e.pageX + 'px';
        bin.style.top = e.pageY + 'px';
        bin.style.color = '#0ff';
        bin.style.fontSize = '28px';
        bin.style.fontWeight = 'bold';
        bin.style.opacity = '0.8';
        bin.style.pointerEvents = 'none';
        bin.style.zIndex = '9999';
        bin.style.fontFamily = 'monospace';
        document.body.appendChild(bin);
        setTimeout(() => bin.remove(), 600);
      });
    });
  </script>
