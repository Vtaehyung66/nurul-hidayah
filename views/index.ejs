<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH | CYBER SYSTEM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net"></script>
    <style>
        /* Base Cyber Theme */
        body { background: #000814; overflow-x: hidden; font-family: 'Courier New', monospace; cursor: crosshair; }
        
        /* Scanline Effect (Monitor Hacker Jadul) */
        body::before {
            content: " "; display: block; position: fixed; top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 100; background-size: 100% 2px, 3px 100%; pointer-events: none;
        }

        #particles-js { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }

        /* Bingkai Robotic Neon Glow */
        .cyber-card {
            background: rgba(1, 15, 30, 0.9);
            border: 1px solid #00f2ff;
            position: relative;
            clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%);
            box-shadow: 0 0 20px rgba(0, 242, 255, 0.15);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .cyber-card::after {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(45deg, transparent 40%, rgba(0, 242, 255, 0.1) 50%, transparent 60%);
            background-size: 200% 200%; animation: shine 3s infinite;
        }

        @keyframes shine { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        .cyber-card:hover {
            box-shadow: 0 0 40px rgba(0, 242, 255, 0.5);
            border-width: 2px; transform: translateY(-5px);
        }

        /* Binary Rain Element */
        .bin-char {
            position: fixed; color: #00f2ff; font-weight: bold; pointer-events: none;
            text-shadow: 0 0 8px #00f2ff; z-index: 1000; animation: explode 0.8s ease-out forwards;
        }

        @keyframes explode {
            0% { transform: translate(0, 0) scale(1); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) scale(0); opacity: 0; }
        }

        .neon-text { text-shadow: 0 0 10px #00f2ff, 0 0 20px #00f2ff; }
    </style>
</head>
<body>
    <div id="particles-js"></div>

    <header class="text-center py-10 relative z-50">
        <h1 class="text-5xl font-black text-cyan-400 neon-text tracking-tighter uppercase mb-2">Nurul Hidayah</h1>
        <div class="bg-cyan-500 text-black px-4 py-1 inline-block text-xs font-bold tracking-widest">CYBERNETIC EDUCATIONAL SYSTEM v2.0</div>
    </header>

    <main class="container mx-auto px-6 py-12 relative z-50">
        <div class="grid md:grid-cols-2 gap-12">
            
            <!-- 01 KB NURUL HIDAYAH -->
            <div class="cyber-card p-10 cursor-pointer group" onclick="spawnBinary(event)">
                <div class="flex justify-between items-center mb-8">
                    <div class="h-1 w-20 bg-cyan-500"></div>
                    <span class="text-6xl font-black text-cyan-500/20 italic group-hover:text-cyan-500/40 transition">01</span>
                </div>
                <h2 class="text-3xl font-bold text-white mb-6 tracking-widest uppercase">KB NURUL HIDAYAH</h2>
                <p class="text-cyan-300 italic mb-8 leading-relaxed border-l-2 border-cyan-500 pl-4 bg-cyan-950/20 py-2">
                    "Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap teknologi sejak usia dini."
                </p>
                <div class="grid gap-4">
                    <div class="p-4 bg-cyan-900/20 border border-cyan-800 hover:border-cyan-400 transition">
                        <span class="text-[10px] text-cyan-500 block mb-1">PROG_01</span>
                        <h3 class="text-cyan-300 font-bold tracking-widest">PENGENALAN TEKNOLOGI</h3>
                        <p class="text-xs text-cyan-100 opacity-70 mt-2">Stimulasi literasi digital aman melalui interaksi multimedia.</p>
                    </div>
                </div>
            </div>

            <!-- 02 MADRASAH IBTIDAIYAH -->
            <div class="cyber-card p-10 cursor-pointer group" onclick="spawnBinary(event)">
                <div class="flex justify-between items-center mb-8">
                    <div class="h-1 w-20 bg-cyan-500"></div>
                    <span class="text-6xl font-black text-cyan-500/20 italic group-hover:text-cyan-500/40 transition">02</span>
                </div>
                <h2 class="text-3xl font-bold text-white mb-6 tracking-widest uppercase">MADRASAH IBTIDAIYAH</h2>
                <div class="flex flex-wrap gap-2 mb-8">
                    <span class="border border-cyan-500 px-3 py-1 text-[10px] text-cyan-400 font-bold hover:bg-cyan-500 hover:text-black transition">TARBIYAH</span>
                    <span class="border border-cyan-500 px-3 py-1 text-[10px] text-cyan-400 font-bold hover:bg-cyan-500 hover:text-black transition">ULUMUDDIN</span>
                    <span class="border border-cyan-500 px-3 py-1 text-[10px] text-cyan-400 font-bold hover:bg-cyan-500 hover:text-black transition">ADAB</span>
                </div>
                <div class="space-y-3 text-sm text-cyan-100 italic">
                    <p class="flex items-center gap-2"><span class="text-cyan-500">>></span> Strategi PAKEM Aktif & Kreatif</p>
                    <p class="flex items-center gap-2"><span class="text-cyan-500">>></span> Pengembangan Akhlakul Karimah</p>
                    <p class="flex items-center gap-2"><span class="text-cyan-500">>></span> Kurikulum Integratif Digital</p>
                </div>
                <div class="mt-12 flex justify-between items-end border-t border-cyan-900 pt-4">
                    <div class="text-[8px] text-cyan-700 font-bold tracking-[0.2em]">SECURITY_PROTOCOL_ACTIVE</div>
                    <div class="w-3 h-3 bg-cyan-500 animate-pulse"></div>
                </div>
            </div>

        </div>
    </main>

    <script>
        // Neuro-Network Background
        particlesJS("particles-js", {
            "particles": {
                "number": { "value": 100, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#00f2ff" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.3, "random": true },
                "size": { "value": 2, "random": true },
                "line_linked": { "enable": true, "distance": 150, "color": "#00f2ff", "opacity": 0.2, "width": 1 },
                "move": { "enable": true, "speed": 1.5, "direction": "none", "random": true, "straight": false, "out_mode": "out" }
            }
        });

        // Binary Burst Logic
        function spawnBinary(e) {
            for(let i=0; i<20; i++) {
                const char = document.createElement('div');
                char.className = 'bin-char';
                char.innerText = Math.random() > 0.5 ? "1" : "0";
                
                // Variabel CSS untuk arah ledakan
                const tx = (Math.random() - 0.5) * 300 + "px";
                const ty = (Math.random() - 0.5) * 300 + "px";
                char.style.setProperty('--tx', tx);
                char.style.setProperty('--ty', ty);
                
                char.style.left = e.clientX + "px";
                char.style.top = e.clientY + "px";
                
                document.body.appendChild(char);
                setTimeout(() => char.remove(), 800);
            }
        }
    </script>
</body>
</html>
