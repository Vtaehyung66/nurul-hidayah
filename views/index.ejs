<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH SCHOOL | CYBER SYSTEM v3.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net"></script>
    <style>
        /* Base Cyber Theme & Monitor Effect */
        body { background: #000c1d; color: #00f2ff; overflow-x: hidden; font-family: 'Courier New', monospace; cursor: crosshair; }
        #particles-js { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }
        
        /* CRT Scanline Overlay */
        body::before {
            content: " "; display: block; position: fixed; top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            z-index: 100; background-size: 100% 3px, 2px 100%; pointer-events: none;
        }

        /* Robotic Glowing Frame */
        .cyber-frame {
            background: rgba(1, 28, 50, 0.85);
            border: 1px solid #00f2ff;
            box-shadow: 0 0 15px rgba(0, 242, 255, 0.3);
            position: relative;
            clip-path: polygon(8% 0, 100% 0, 100% 92%, 92% 100%, 0 100%, 0 8%);
            transition: all 0.4s ease;
        }
        .cyber-frame:hover { box-shadow: 0 0 30px rgba(0, 242, 255, 0.7); transform: scale(1.02); border-width: 2px; }

        /* Binary Particle Click Animation */
        .bin-char {
            position: fixed; color: #00f2ff; font-weight: bold; pointer-events: none;
            text-shadow: 0 0 10px #00f2ff; z-index: 1000; animation: binaryExplode 1s ease-out forwards;
        }
        @keyframes binaryExplode {
            0% { transform: translate(0, 0) scale(1.5); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) rotate(360deg) scale(0); opacity: 0; }
        }

        .neon-glow { text-shadow: 0 0 15px #00f2ff, 0 0 5px #00f2ff; }
        .staff-border { border: 1px solid rgba(0, 242, 255, 0.5); filter: hue-rotate(180deg) brightness(1.2); }
        .cyber-line { height: 2px; background: linear-gradient(90deg, transparent, #00f2ff, transparent); }
    </style>
</head>
<body onmousedown="createBinaryBurst(event)">
    <div id="particles-js"></div>

    <div class="container mx-auto px-6 py-10 relative z-50">
        
        <!-- TOP LOGO & PALESTINE EMBLEM (Mirip Foto) -->
        <div class="flex justify-between items-start mb-12">
            <div class="w-16 h-24 cyber-frame flex items-center justify-center opacity-70">
                <span class="text-[8px] text-center font-bold">PALESTINE<br>MAP_LINK</span>
            </div>
            <div class="text-right">
                <h1 class="text-4xl font-black neon-glow tracking-widest uppercase italic">NURUL HIDAYAH SCHOOL</h1>
                <div class="cyber-line mt-2"></div>
            </div>
        </div>

        <!-- MAIN CYBER CLASSROOM (Hero Section) -->
        <div class="cyber-frame p-3 mb-16 mx-auto max-w-4xl">
            <div class="bg-cyan-950 h-80 flex items-center justify-center overflow-hidden relative">
                <div class="absolute inset-0 bg-[url('https://source.unsplash.com')] bg-cover opacity-40"></div>
                <div class="relative z-10 text-center">
                    <div class="border-2 border-cyan-400 p-4 backdrop-blur-md">
                        <span class="text-xs tracking-[0.5em] animate-pulse">SYSTEM_ACTIVE: DIGITAL_EDUCATION_CORE</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- STAFF GRID (8 GURU SESUAI FOTO) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
            <script>
                const staff = ["SITI RAHMAH", "AHMAD HIDAYAT", "FATIMAH ZAHRA", "HASANUDDIN", "MAIMUNAH", "MUSTAFA", "LATIFAH", "ZAID"];
                staff.forEach(name => {
                    document.write(`
                        <div class="group cursor-pointer">
                            <div class="cyber-frame p-2 mb-3">
                                <div class="bg-cyan-900/50 h-32 flex items-center justify-center staff-border overflow-hidden">
                                     <img src="https://api.dicebear.com{name}" class="w-20 h-20 opacity-80 group-hover:scale-110 transition">
                                </div>
                            </div>
                            <div class="bg-cyan-500 text-black text-[10px] font-black py-1 tracking-widest text-center uppercase">${name}</div>
                        </div>
                    `);
                });
            </script>
        </div>

        <!-- VISION & MISSION (2 KOLOM) -->
        <div class="grid md:grid-cols-2 gap-10 mb-20">
            <div class="cyber-frame p-8 border-l-4 border-cyan-400 relative">
                <div class="absolute -top-3 left-4 bg-blue-900 px-3 text-[10px] font-bold">DATA_MODULE: 01</div>
                <h3 class="text-xl font-bold mb-4 italic underline decoration-cyan-500">PROGRAM & VISION</h3>
                <ul class="text-xs space-y-3 opacity-90 tracking-wider">
                    <li>[#] Professional, child-centric education and school innovation.</li>
                    <li>[#] Focus on developing leadership skills through Islamic values.</li>
                    <li>[#] Child-centric: focuses on nurturing talent and creativity.</li>
                </ul>
            </div>
            <div class="cyber-frame p-8 border-r-4 border-cyan-400 relative">
                <div class="absolute -top-3 right-4 bg-blue-900 px-3 text-[10px] font-bold">DATA_MODULE: 02</div>
                <h3 class="text-xl font-bold mb-4 italic underline decoration-cyan-500">MISSION & STRATEGY</h3>
                <ul class="text-xs space-y-3 opacity-90 tracking-wider">
                    <li>[#] To foster integrated education, edaction, and holistic development.</li>
                    <li>[#] Mission to develop excellence in global citizenship and faith.</li>
                    <li>[#] Strategic focus on digital literacy and spiritual integrity.</li>
                </ul>
            </div>
        </div>

        <!-- SEJARAH PENDIRIAN (Center Layout) -->
        <div class="max-w-3xl mx-auto text-center mb-24">
            <h2 class="text-3xl font-black tracking-[0.4em] uppercase mb-1 neon-glow">SEJARAH PENDIRIAN</h2>
            <p class="text-[10px] tracking-[0.2em] text-cyan-500 mb-10">NURUL HIDAYAH SCHOOL INFRASTRUCTURE</p>
            
            <div class="cyber-frame w-56 h-56 mx-auto mb-10 p-4 flex items-center justify-center">
                <div class="border-2 border-dashed border-cyan-500 w-full h-full flex flex-col items-center justify-center opacity-60">
                    <span class="text-[10px] font-bold">FOTO_PENDIRI.JPG</span>
                    <span class="text-[8px]">ENCRYPTED_FILE</span>
                </div>
            </div>

            <div class="text-center">
                <h4 class="text-sm font-bold text-cyan-400 mb-4">[ KETERANGAN SEJARAH ]</h4>
                <div class="cyber-frame p-6 text-[12px] leading-relaxed text-justify italic bg-cyan-900/10">
                    Sekolah ini didirikan pada tahun 1970 dengan cita-cita besar untuk menyelaraskan pendidikan agama Islam yang murni dengan kemajuan ilmu pengetahuan modern. Berawal dari satu gedung kecil, Nurul Hidayah bertransformasi menjadi pusat pendidikan berbasis Cyber yang tetap menjaga akar Akhlakul Karimah. Sejarah ini adalah bukti bahwa integritas spiritual dan keunggulan teknologi dapat bersimbiosis menciptakan generasi Rabbani yang tak terkalahkan oleh zaman.
                </div>
            </div>
        </div>

        <!-- FOOTER HEXAGON DECORATION -->
        <footer class="flex justify-center opacity-20">
            <div class="w-10 h-10 border border-cyan-500 rotate-45"></div>
            <div class="w-10 h-10 border border-cyan-500 rotate-45 mx-4"></div>
            <div class="w-10 h-10 border border-cyan-500 rotate-45"></div>
        </footer>
    </div>

    <script>
        // Neural Network Background Particles
        particlesJS("particles-js", {
            "particles": {
                "number": { "value": 100, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#00f2ff" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.5, "random": true },
                "size": { "value": 3, "random": true },
                "line_linked": { "enable": true, "distance": 150, "color": "#00f2ff", "opacity": 0.3, "width": 1 },
                "move": { "enable": true, "speed": 2, "direction": "none", "out_mode": "out" }
            },
            "interactivity": {
                "events": { "onhover": { "enable": true, "mode": "grab" } }
            }
        });

        // Binary 1010 Explosion Function
        function createBinaryBurst(e) {
            for(let i=0; i<15; i++) {
                const b = document.createElement('div');
                b.className = 'bin-char';
                b.innerText = Math.random() > 0.5 ? "1" : "0";
                
                // Randomize trajectory
                const tx = (Math.random() - 0.5) * 300 + "px";
                const ty = (Math.random() - 0.5) * 300 + "px";
                b.style.setProperty('--tx', tx);
                b.style.setProperty('--ty', ty);
                
                b.style.left = e.clientX + "px";
                b.style.top = e.clientY + "px";
                
                document.body.appendChild(b);
                setTimeout(() => b.remove(), 1000);
            }
        }
    </script>
</body>
</html>