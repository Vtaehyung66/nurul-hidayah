<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH SCHOOL</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ibm-blue: #0f62fe;
            --ibm-black: #161616;
            --ibm-gray: #f4f4f4;
            --text-main: #393939;
            --shadow-pop: 0 25px 50px rgba(0, 0, 0, 0.18);
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            margin: 0;
            padding: 0;
            color: var(--text-main);
            background: linear-gradient(135deg, #87CEEB 0%, #ADD8E6 25%, #B0E0E6 50%, #87CEEB 75%, #ADD8E6 100%);
            background-size: 400% 400%;
            background-attachment: fixed;
            line-height: 1.7;
            overflow-x: hidden;
            position: relative;
            animation: gradientShift 15s ease infinite;
        }

        @keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
            100% {
                background-position: 0% 50%;
            }
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.1) 0%, transparent 40%),
                radial-gradient(circle at 40% 80%, rgba(255, 255, 255, 0.12) 0%, transparent 35%),
                radial-gradient(circle at 90% 20%, rgba(255, 255, 255, 0.08) 0%, transparent 40%);
            pointer-events: none;
            z-index: 0;
            animation: floatAnimation 20s ease-in-out infinite;
        }

        @keyframes floatAnimation {
            0%, 100% {
                opacity: 0.8;
            }
            50% {
                opacity: 1;
            }
        }

        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                linear-gradient(45deg, rgba(255, 255, 255, 0.03) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.03) 75%, rgba(255, 255, 255, 0.03)),
                linear-gradient(45deg, rgba(255, 255, 255, 0.03) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.03) 75%, rgba(255, 255, 255, 0.03));
            background-size: 60px 60px;
            background-position: 0 0, 30px 30px;
            pointer-events: none;
            z-index: 0;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 25px;
            position: relative;
            z-index: 1;
        }

        header {
            text-align: center;
            padding: 50px 20px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 32px rgba(31, 38, 135, 0.25);
            margin-bottom: 30px;
        }

        /* HEADER LOGO LAYOUT */
        .header-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: clamp(15px, 5vw, 40px);
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .logo-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .logo-container {
            width: clamp(80px, 12vw, 140px);
            height: clamp(80px, 12vw, 140px);
            border-radius: 50%;
            background: rgba(15, 98, 254, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid var(--ibm-blue);
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(15, 98, 254, 0.2);
        }

        .logo-container:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(15, 98, 254, 0.3);
            background: rgba(15, 98, 254, 0.15);
        }

        .logo-container img {
            width: 85%;
            height: 85%;
            object-fit: contain;
        }

        .logo-text {
            font-size: clamp(0.7rem, 1.8vw, 0.9rem);
            color: var(--ibm-blue);
            font-weight: 600;
            text-align: center;
            line-height: 1.3;
            max-width: 140px;
        }

        .title-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        h1 {
            font-size: clamp(2rem, 8vw, 3.8rem);
            font-weight: 700;
            margin: 0;
            color: var(--ibm-black);
            letter-spacing: -1px;
            background: linear-gradient(135deg, #0f62fe, #ff6b99);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: clamp(0.9rem, 3vw, 1.3rem);
            color: var(--ibm-blue);
            margin: 0;
            font-weight: 400;
        }

        .pop-effect {
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            cursor: pointer;
            border: 1px solid #efefef;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
        }

        .pop-effect:hover {
            transform: translateY(-12px) scale(1.02);
            box-shadow: 0 15px 40px rgba(31, 38, 135, 0.25);
            border-color: var(--ibm-blue);
        }

        .lightbox {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(5px);
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .lightbox.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-content {
            position: relative;
            width: 90vw;
            max-width: 900px;
            animation: slideUp 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        @keyframes slideUp {
            from {
                transform: scale(0.7) translateY(40px);
                opacity: 0;
            }
            to {
                transform: scale(1) translateY(0);
                opacity: 1;
            }
        }

        .lightbox-img {
            width: 100%;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 0 60px rgba(0, 0, 0, 0.7);
        }

        .close-lightbox {
            position: absolute;
            top: -40px;
            right: 0;
            color: #fff;
            font-size: 36px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.2);
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            line-height: 1;
            border: none;
        }

        .close-lightbox:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.1);
        }

        .hero-gallery {
            display: flex;
            flex-direction: column;
            gap: 30px;
            margin: 40px 0 60px;
        }

        .frame-large {
            width: 100%;
            height: clamp(250px, 45vh, 500px);
            background: rgba(255, 255, 255, 0.88);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            cursor: pointer;
            overflow: hidden;
            position: relative;
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 30px rgba(31, 38, 135, 0.2);
        }

        .frame-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .frame-large p {
            font-size: clamp(0.95rem, 2.5vw, 1.4rem);
            color: #aaa;
            position: absolute;
        }

        .matrix-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 20px;
            margin: 80px 0 60px;
        }

        .frame-medium {
            aspect-ratio: 1 / 1.2;
            background: rgba(255, 255, 255, 0.85);
            border-radius: 8px;
            cursor: pointer;
            overflow: hidden;
            position: relative;
            backdrop-filter: blur(8px);
            box-shadow: 0 6px 25px rgba(31, 38, 135, 0.15);
            transition: all 0.3s ease;
        }

        .frame-medium:hover {
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 10px 35px rgba(31, 38, 135, 0.22);
            transform: translateY(-5px);
        }

        .frame-medium img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .section-title {
            text-align: center;
            font-size: clamp(1.8rem, 6vw, 2.8rem);
            margin: 80px 0 50px;
            border-bottom: 2px solid var(--ibm-blue);
            display: block;
            padding-bottom: 15px;
            color: var(--ibm-black);
            text-shadow: 0 2px 4px rgba(255, 255, 255, 0.5);
            font-weight: 700;
        }

        .visi-misi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 35px;
            margin-bottom: 80px;
            align-items: start;
        }

        .kolom-teks {
            background: rgba(255, 255, 255, 0.95);
            padding: 30px;
            border-radius: 10px;
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 28px rgba(31, 38, 135, 0.2);
        }

        .kolom-teks h3 {
            color: var(--ibm-blue);
            border-left: 6px solid var(--ibm-blue);
            padding-left: 18px;
            margin: 30px 0 20px;
            font-size: clamp(1.3rem, 4vw, 1.8rem);
        }

        .kolom-teks h4 {
            font-size: clamp(1rem, 2.3vw, 1.2rem);
            margin: 22px 0 12px;
            color: var(--ibm-black);
            border-bottom: 1px solid #ddd;
            display: inline-block;
        }

        .kolom-teks p {
            margin-bottom: 16px;
            text-align: justify;
            font-size: clamp(0.9rem, 1.8vw, 1rem);
            line-height: 1.7;
        }

        .kolom-teks ul {
            padding-left: 20px;
            margin-bottom: 20px;
        }

        .kolom-teks ul li {
            margin-bottom: 8px;
            font-size: clamp(0.9rem, 1.8vw, 1rem);
            line-height: 1.6;
        }

        .guru-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: clamp(25px, 4vw, 50px);
            margin: 80px 0 60px;
            text-align: center;
        }

        .guru-card {
            position: relative;
            background: rgba(255, 255, 255, 0.9);
            padding: 18px;
            border-radius: 12px;
            backdrop-filter: blur(8px);
            box-shadow: 0 6px 24px rgba(31, 38, 135, 0.15);
            transition: all 0.3s ease;
        }

        .guru-card:hover {
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 10px 35px rgba(31, 38, 135, 0.25);
            transform: translateY(-8px);
        }

        .guru-card img {
            width: clamp(100px, 18vw, 200px);
            height: clamp(100px, 18vw, 200px);
            border-radius: 50%;
            background: var(--ibm-gray);
            margin: 0 auto 16px;
            object-fit: cover;
            border: 4px solid #f0f0f0;
            transition: all 0.4s ease;
            cursor: pointer;
            display: block;
        }

        .guru-card:hover img {
            border-color: var(--ibm-blue);
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(15, 98, 254, 0.3);
        }

        .guru-name {
            font-weight: 600;
            font-size: clamp(0.95rem, 2.2vw, 1.15rem);
            color: var(--ibm-black);
            margin-bottom: 4px;
            display: block;
        }

        .guru-role {
            font-size: clamp(0.8rem, 1.5vw, 0.9rem);
            color: #666;
            font-style: italic;
        }

        .history-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 40px;
            background: rgba(255, 255, 255, 0.95);
            padding: clamp(35px, 6vw, 60px);
            margin-top: 80px;
            margin-bottom: 80px;
            border-radius: 10px;
            border-left: 8px solid var(--ibm-blue);
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 28px rgba(31, 38, 135, 0.2);
        }

        .founder-container {
            text-align: center;
        }

        .founder-frame {
            width: 100%;
            height: clamp(280px, 35vh, 450px);
            background: #fff;
            margin-bottom: 18px;
            overflow: hidden;
            border: 1px solid #ddd;
            border-radius: 8px;
            cursor: pointer;
            position: relative;
        }

        .founder-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .founder-frame:hover img {
            transform: scale(1.05);
        }

        .founder-container p {
            font-size: clamp(0.95rem, 2.2vw, 1.05rem);
            font-weight: 600;
            color: var(--ibm-black);
        }

        .history-text {
            font-size: clamp(0.95rem, 1.8vw, 1.1rem);
            text-align: justify;
            align-self: center;
            line-height: 1.9;
            color: #333;
        }

        .animate-on-scroll {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s ease-out;
        }

        .animate-on-scroll.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* KONTAK SECTION */
        .contact-section {
            background: rgba(240, 240, 240, 0.95);
            padding: clamp(40px, 6vw, 60px);
            margin-top: 60px;
            margin-bottom: 0;
            border-radius: 10px;
            backdrop-filter: blur(8px);
            box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
        }

        .contact-title {
            text-align: center;
            font-size: clamp(1.5rem, 4vw, 2rem);
            color: var(--ibm-black);
            margin-bottom: 40px;
            font-weight: 700;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .contact-card {
            background: rgba(255, 255, 255, 0.9);
            padding: 25px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(31, 38, 135, 0.12);
            transition: all 0.3s ease;
            backdrop-filter: blur(6px);
        }

        .contact-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 8px 25px rgba(31, 38, 135, 0.25);
            background: rgba(255, 255, 255, 0.95);
        }

        .contact-icon {
            font-size: 3rem;
            color: var(--ibm-blue);
            margin-bottom: 15px;
            display: inline-block;
            transition: transform 0.3s ease;
        }

        .contact-card:hover .contact-icon {
            transform: scale(1.1);
        }

        .contact-text {
            font-size: clamp(0.95rem, 2vw, 1.05rem);
            color: var(--ibm-black);
            font-weight: 600;
            margin-bottom: 8px;
            word-break: break-word;
        }

        .contact-label {
            font-size: clamp(0.8rem, 1.5vw, 0.9rem);
            color: #666;
            font-style: italic;
        }

        /* FOOTER SECTION */
        .footer-section {
            position: relative;
            height: clamp(250px, 50vh, 400px);
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            margin-top: 0;
            overflow: hidden;
        }

        .footer-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%);
            z-index: 1;
        }

        .footer-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: clamp(20px, 4vw, 40px);
            color: white;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        .creator-text {
            font-size: clamp(0.95rem, 2.5vw, 1.3rem);
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .container {
                padding: 20px 15px;
            }

            header {
                padding: 35px 15px;
                margin-bottom: 25px;
            }

            .header-wrapper {
                gap: clamp(10px, 3vw, 25px);
            }

            .logo-container {
                width: clamp(70px, 10vw, 110px);
                height: clamp(70px, 10vw, 110px);
            }

            .logo-text {
                font-size: clamp(0.65rem, 1.5vw, 0.85rem);
            }

            .matrix-grid {
                gap: 15px;
                margin: 60px 0 50px;
            }

            .guru-grid {
                gap: clamp(18px, 3vw, 35px);
                margin: 60px 0 50px;
            }

            .contact-section {
                padding: 30px 20px;
            }

            .contact-grid {
                gap: 20px;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 12px 10px;
            }

            header {
                padding: 25px 12px;
            }

            .header-wrapper {
                gap: 12px;
                margin-bottom: 15px;
            }

            .logo-container {
                width: clamp(65px, 8vw, 90px);
                height: clamp(65px, 8vw, 90px);
                border-width: 2px;
            }

            .logo-text {
                font-size: clamp(0.6rem, 1.2vw, 0.75rem);
                max-width: 110px;
            }

            .title-section h1 {
                font-size: clamp(1.8rem, 6vw, 2.8rem);
            }

            .matrix-grid {
                grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
                gap: 10px;
                margin: 40px 0 40px;
            }

            .hero-gallery {
                gap: 20px;
                margin: 20px 0 40px;
            }

            .guru-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: clamp(12px, 3vw, 25px);
            }

            .visi-misi-grid {
                gap: 20px;
            }

            .history-section {
                grid-template-columns: 1fr;
                padding: 20px 15px;
                gap: 25px;
            }

            .contact-grid {
                grid-template-columns: 1fr;
            }

            .contact-card {
                padding: 20px;
            }

            .footer-section {
                height: clamp(200px, 40vh, 350px);
            }

            .creator-text {
                font-size: clamp(0.9rem, 2vw, 1.1rem);
            }
        }
    </style>
</head>
<body>

<!-- LIGHTBOX MODAL -->
<div id="lightbox" class="lightbox">
    <div class="lightbox-content">
        <button class="close-lightbox">&times;</button>
        <img id="lightbox-img" class="lightbox-img" src="" alt="Gambar Diperbesar">
    </div>
</div>

<div class="container">
    <header class="animate-on-scroll">
        <!-- HEADER DENGAN LOGO -->
        <div class="header-wrapper">
            <!-- LOGO KIRI -->
            <div class="logo-section">
                <div class="logo-container">
                    <img src="/img/logo-paud.png" alt="Logo PAUD">
                </div>
                <div class="logo-text">PAUD KOBER<br>NURUL HIDAYAH</div>
            </div>

            <!-- JUDUL UTAMA -->
            <div class="title-section">
                <h1>NURUL HIDAYAH</h1>
                <p class="subtitle">Pendidikan Berbasis Agama Islam, Formal, seni & Teknologi</p>
            </div>

            <!-- LOGO KANAN -->
            <div class="logo-section">
                <div class="logo-container">
                    <img src="/img/logo-diniyah.png" alt="Logo Diniyah">
                </div>
                <div class="logo-text">DINIYAH<br>TAKMILIYAH<br>NURUL HIDAYAH</div>
            </div>
        </div>
    </header>

    <!-- 4 BINGKAI DOKUMENTASI UTAMA -->
    <section class="hero-gallery">
        <div class="frame-large pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <p>DOKUMENTASI UTAMA 1</p>
            <img src="/img/doc1.jpg" alt="Dokumentasi 1" style="display: none;">
        </div>
        <div class="frame-large pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <p>DOKUMENTASI UTAMA 2</p>
            <img src="/img/doc2.jpg" alt="Dokumentasi 2" style="display: none;">
        </div>
        <div class="frame-large pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <p>DOKUMENTASI UTAMA 3</p>
            <img src="/img/doc3.jpg" alt="Dokumentasi 3" style="display: none;">
        </div>
        <div class="frame-large pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <p>DOKUMENTASI UTAMA 4</p>
            <img src="/img/doc4.jpg" alt="Dokumentasi 4" style="display: none;">
        </div>
    </section>

    <!-- 10 BINGKAI GALERI (5 ATAS, 5 BAWAH) -->
    <div class="matrix-grid">
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <img src="/img/galeri1.jpg" alt="Galeri 1">
        </div>
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <img src="/img/galeri2.jpg" alt="Galeri 2">
        </div>
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <img src="/img/galeri3.jpg" alt="Galeri 3">
        </div>
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <img src="/img/galeri4.jpg" alt="Galeri 4">
        </div>
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
            <img src="/img/galeri5.jpg" alt="Galeri 5">
        </div>
        <div class="frame-medium pop-effect animate-on-scroll" onclick="openLightbox(this.querySelector('img') ? this.querySelector('img').src : '')">
