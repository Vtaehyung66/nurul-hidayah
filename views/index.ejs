<<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= nama %> | Excellence in Education</title>
    
    <!-- Framework & Fonts Premium -->
    <link href="https://cdn.jsdelivr.net" rel="stylesheet">
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">

    <style>
        :root {
            --primary: #0f172a; /* Navy Corporate */
            --accent: #2563eb;  /* Blue Modern */
            --soft-bg: #f8fafc;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--soft-bg);
            color: var(--primary);
            overflow-x: hidden;
        }

        /* Navbar Floating Glassmorphism */
        .navbar {
            backdrop-filter: blur(15px);
            background: rgba(255, 255, 255, 0.8);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 20px 0;
            transition: 0.4s;
        }

        /* Hero Section ala Tech Startup */
        .hero {
            padding: 180px 0 100px 0;
            background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.05), transparent),
                        radial-gradient(circle at bottom left, rgba(15, 23, 42, 0.03), transparent);
        }

        .hero h1 {
            font-weight: 800;
            font-size: 4rem;
            letter-spacing: -2px;
            line-height: 1.1;
            margin-bottom: 25px;
        }

        .hero .text-gradient {
            background: linear-gradient(to right, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Button Luxury */
        .btn-pro {
            background: var(--primary);
            color: white;
            padding: 16px 35px;
            border-radius: 14px;
            font-weight: 700;
            border: none;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
        }

        .btn-pro:hover {
            transform: translateY(-5px);
            background: var(--accent);
            color: white;
            box-shadow: 0 20px 30px rgba(37, 99, 235, 0.2);
        }

        /* Card Modern Minimalist */
        .feature-card {
            background: white;
            border: 1px solid rgba(0,0,0,0.03);
            border-radius: 30px;
            padding: 50px 40px;
            transition: 0.5s ease;
            height: 100%;
        }

        .feature-card:hover {
            border-color: var(--accent);
            box-shadow: 0 40px 60px -15px rgba(0, 0, 0, 0.07);
            transform: translateY(-15px);
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            background: #f1f5f9;
            color: var(--accent);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 30px;
            transition: 0.4s;
        }

        .feature-card:hover .icon-circle {
            background: var(--accent);
            color: white;
            transform: rotate(-10deg);
        }

        /* Stats Section */
        .stats-box {
            background: var(--primary);
            color: white;
            padding: 80px 0;
            border-radius: 50px;
            margin-top: 50px;
        }

        footer {
            padding: 80px 0 40px;
            border-top: 1px solid rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>

    <!-- Header / Navigation -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand text-dark fw-bold" href="#">
                <i class="bi bi-layers-half text-primary me-2"></i>NH ACADEMY
            </a>
            <div class="ms-auto d-none d-lg-block">
                <a href="mailto:<%= email %>" class="btn btn-pro btn-sm py-2">Admission 2026</a>
            </div>
        </div>
    </nav>

    <!-- Main Hero -->
    <header class="hero text-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <span class="badge rounded-pill px-4 py-2 bg-light text-primary border mb-4">World Class Education</span>
                    <h1 class="text-gradient">Innovation In Learning,<br>Legacy In Character.</h1>
                    <p class="lead text-muted mb-5 col-lg-8 mx-auto">
                        Selamat Datang di <strong><%= nama %></strong>. Kami melampaui batas pendidikan tradisional untuk mencetak pemimpin masa depan yang berintegritas.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <button class="btn btn-pro">Explore Programs</button>
                        <button class="btn btn-light border px-4 py-3 rounded-4 fw-bold">Watch Virtual Tour</button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services / Features -->
    <section class="container mb-5 py-5">
        <div class="row g-5">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon-circle"><i class="bi bi-cpu"></i></div>
                    <h3 class="fw-bold h4">Digital Ecosystem</h3>
                    <p class="text-muted lh-lg">Integrasi penuh teknologi AI dan komputasi awan dalam setiap kurikulum pembelajaran harian.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon-circle"><i class="bi bi-globe-americas"></i></div>
                    <h3 class="fw-bold h4">Global Network</h3>
                    <p class="text-muted lh-lg">Kemitraan strategis dengan institusi internasional untuk pertukaran pelajar dan wawasan global.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon-circle"><i class="bi bi-award"></i></div>
                    <h3 class="fw-bold h4">Moral Integrity</h3>
                    <p class="text-muted lh-lg">Fokus utama pada pembentukan akhlakul karimah sebagai fondasi kecerdasan intelektual.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Banner -->
    <div class="container">
        <div class="stats-box text-center">
            <div class="row justify-content-center">
                <div class="col-md-3">
                    <h2 class="display-5 fw-bold">15+</h2>
                    <p class="text-white-50">Years Excellence</p>
                </div>
                <div class="col-md-3">
                    <h2 class="display-5 fw-bold">500+</h2>
                    <p class="text-white-50">Active Students</p>
                </div>
                <div class="col-md-3">
                    <h2 class="display-5 fw-bold">100%</h2>
                    <p class="text-white-50">College Acceptance</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-5">
        <div class="container text-center">
            <h4 class="fw-bold mb-4">SCHOOL NURUL HIDAYAH</h4>
            <p class="text-muted mb-5">Professionalism. Integrity. Future-Ready.</p>
            <div class="mb-4">
                <a href="#" class="text-dark mx-3 text-decoration-none fw-bold">Curriculum</a>
                <a href="#" class="text-dark mx-3 text-decoration-none fw-bold">Admissions</a>
                <a href="#" class="text-dark mx-3 text-decoration-none fw-bold">Privacy</a>
            </div>
            <p class="small text-muted">&copy; 2026 <%= nama %>. Powered by Vercel Edge Network.</p>
        </div>
    </footer>

</body>
</html>
