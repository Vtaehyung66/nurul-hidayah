<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH | Cyber Hub Education</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --neon-blue: #00f2ff;
        }

        /* BACKGROUND MENGGUNAKAN GAMBAR HUD */
        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background: 
                linear-gradient(180deg, rgba(255,255,255,0.8) 0%, rgba(135,206,235,0.6) 45%, rgba(0,29,108,0.4) 100%),
                url('https://as1.ftcdn.net');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            overflow-x: hidden;
            color: #161616;
        }

        /* EFEK 3D GLASS FRAME */
        .glass-frame {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            transform: perspective(1000px) rotateX(2deg);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            position: relative;
        }

        .glass-frame:hover {
            transform: perspective(1000px) rotateX(0deg) scale(1.02);
            border-color: var(--neon-blue);
            box-shadow: 0 0 30px rgba(0, 242, 255, 0.3);
        }

        /* SISTEM PERCIKAN LISTRIK */
        .spark-container {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none; z-index: 9999;
        }
        .spark {
            position: absolute; width: 4px; height: 4px;
            background: var(--neon-blue); border-radius: 50%;
            box-shadow: 0 0 15px var(--neon-blue);
        }

        .title-huge {
            font-family: 'Orbitron', sans-serif;
            color: #002d9c;
            text-shadow: 0 0 20px rgba(255, 255, 255, 1);
        }

        /* NUANSA CYBER SCANNER */
        .cyber-scanner {
            position: fixed; top: 0; left: 0; width: 100%; height: 2px;
            background: rgba(0, 242, 255, 0.2); z-index: 100;
            animation: scan 10s linear infinite;
        }
        @keyframes scan { 0% { top: 0%; } 100% { top: 100%; } }
    </style>
</head>
<body class="antialiased">

    <div class="cyber-scanner"></div>
    <div class="spark-container" id="spark-container"></div>

    <header class="pt-24 pb-12 px-6 text-center">
        <div data-aos="fade-down" class="mb-8">
            <span class="px-6 py-3 bg-blue-900 text-white text-[10px] tracking-[0.5em] uppercase font-bold rounded-sm shadow-xl inline-block">
                Pendidikan Berbasis agama islam, formal & Teknologi
            </span>
        </div>
        
        <h1 class="title-huge text-6xl md:text-9xl font-extrabold mb-16 tracking-tighter" data-aos="zoom-in">
            NURUL HIDAYAH
        </h1>

        <!-- MEGA HERO FRAME -->
        <div class="max-w-7xl mx-auto px-4 mb-28" data-aos="fade-up">
            <div class="glass-frame p-3 rounded-lg overflow-hidden">
                <div class="aspect-[21/9] relative rounded-md overflow-hidden bg-black/20">
                    <img src="https://images.unsplash.com" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-blue-900/60 to-transparent"></div>
                    <div class="absolute bottom-10 left-10 text-left text-white">
                        <p class="font-bold text-2xl md:text-4xl tracking-tight">MAIN_ARCHIVE_HUD_00</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 space-y-40 pb-40">

        <!-- 6 DOKUMENTASI -->
        <section class="grid grid-cols-2 md:grid-cols-3 gap-10">
            <% for(let i=1; i<=6; i++) { %>
            <div class="glass-frame p-2 group" data-aos="fade-up" data-aos-delay="<%= i*100 %>">
                <div class="aspect-video overflow-hidden rounded-sm">
                    <img src="https://picsum.photos<%= i+200 %>/800/450" class="w-full h-full object-cover group-hover:scale-110 transition-transform">
                </div>
                <div class="p-3 text-[9px] font-bold text-blue-900 tracking-widest opacity-60 uppercase">System_Rec_0<%= i %></div>
            </div>
            <% } %>
        </section>

        <!-- VISI MISI -->
        <section class="grid md:grid-cols-2 gap-12">
            <div class="bg-white/85 backdrop-blur-xl p-10 md:p-16 border-t-8 border-blue-600 shadow-2xl rounded-xl" data-aos="fade-right">
                <h2 class="text-blue-700 font-bold text-xs uppercase tracking-widest mb-6">KB NURUL HIDAYAH</h2>
                <div class="space-y-6 text-sm leading-relaxed text-justify">
                    <p class="text-2xl text-blue-950 font-light italic border-l-4 border-cyan-400 pl-6 bg-blue-50 py-6">"Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap perkembangan teknologi."</p>
                    <p class="font-bold">PAI: Internalisasi nilai Islami melalui metode fun learning.</p>
                    <p>Pengenalan Teknologi: Multimedia interaktif sebagai stimulasi kognitif anak.</p>
                </div>
            </div>

            <div class="bg-white/85 backdrop-blur-xl p-10 md:p-16 border-t-8 border-cyan-400 shadow-2xl rounded-xl" data-aos="fade-left">
                <h2 class="text-blue-700 font-bold text-xs uppercase tracking-widest mb-6">MI NURUL HIDAYAH</h2>
                <div class="space-y-6 text-sm leading-relaxed">
                    <div class="p-6 bg-white/50 border border-blue-50">
                        <h4 class="font-bold text-blue-900 mb-2 uppercase text-[10px]">Kurikulum Keislaman</h4>
                        <p>Madrasah Diniyah Takmiliyah, pembentukan Adab, dan penguasaan Ulumuddin mendalam.</p>
                    </div>
                    <div class="p-6 bg-white/50 border border-blue-50">
                        <h4 class="font-bold text-blue-900 mb-2 uppercase text-[10px]">Islamic Environment</h4>
                        <p>Lingkungan Rahmatan lil 'Alamiin untuk kedamaian dan pembentukan karakter.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PENGELOLA -->
        <section>
            <h2 class="text-center text-4xl font-black text-blue-900 mb-20 uppercase tracking-tighter" data-aos="fade-up">Elite Staff</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
                <% 
                const staff = [
                    {n: "IMAT JUNAEDAH.SPDI", j: "Kepala Sekolah"},
                    {n: "ATANG ABDURAHMAN", j: "Manager"},
                    {n: "MASPUPAH.SPD", j: "Sekertaris"},
                    {n: "APIPULLOH ASHIDIQ.S.TI", j: "Operator"},
                    {n: "SRI INDAH", j: "Guru"},
                    {n: "NABILA FAUZIAH", j: "Guru"},
                    {n: "SALWA NOVIYANTI", j: "Guru"},
                    {n: "JAJANG NURJAMAN", j: "Bendahara"}
                ];
                staff.forEach((s, i) => { %>
                <div class="text-center group" data-aos="zoom-in" data-aos-delay="<%= i*50 %>">
                    <div class="glass-frame p-3 aspect-square rounded-full mb-6 flex items-center justify-center">
                        <div class="w-full h-full rounded-full bg-slate-100 flex items-center justify-center">
                             <svg class="w-10 h-10 text-blue-200" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z""")/>></svg>
                        </div>
                    </div>
                    <h4 class="text-[11px] font-bold text-blue-900 uppercase tracking-wider"><%= s.n %></h4>
                    <p class="text-[8px] text-blue-700/60 font-bold uppercase mt-2"><%= s.j %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <!-- SEJARAH -->
        <section class="glass-frame p-16 md:p-24 rounded-3xl" data-aos="fade-up">
            <div class="grid md:grid-cols-12 gap-16 items-center">
                <div class="md:col-span-4 text-center">
                    <div class="glass-frame p-3 rotate-3 bg-white">
                        <div class="aspect-[3/4] bg-slate-100 flex items-center justify-center italic text-slate-300 text-[10px] font-bold">FOUNDER_PHOTO</div>
                    </div>
                    <h3 class="mt-8 text-2xl font-bold text-blue-950 uppercase">KH. MUSTOFA.MUI</h3>
                </div>
                <div class="md:col-span-8 text-xl font-light text-gray-800 leading-loose">
                    <h2 class="text-5xl font-black text-blue-950 mb-10 tracking-tighter">Legacy & Vision</h2>
                    <p class="text-justify italic border-l-4 border-cyan-400 pl-6">"Setiap anak adalah amanah, dan sejarah kami adalah perjalanan panjang menjaga amanah tersebut."</p>
                </div>
            </div>
        </section>

    </main>

    <footer class="py-20 border-t border-blue-200 bg-white/20 text-center">
        <p class="text-[10px] font-bold text-blue-900 uppercase tracking-[1em] animate-pulse">Faith • Technology • Future</p>
    </footer>

    <script src="https://unpkg.com"></script>
    <script>
        AOS.init({ duration: 1000, once: true });

        // SPARKS SYSTEM
        document.addEventListener('mousedown', (e) => {
            const container = document.getElementById('spark-container');
            for(let i=0; i<15; i++) {
                const spark = document.createElement('div');
                spark.className = 'spark';
                spark.style.left = e.clientX + 'px';
                spark.style.top = e.clientY + 'px';
                container.appendChild(spark);

                const angle = Math.random() * Math.PI * 2;
                const velocity = Math.random() * 150 + 50;
                
                spark.animate([
                    { transform: 'translate(0, 0) scale(1)', opacity: 1 },
                    { transform: `translate(${Math.cos(angle)*velocity}px, ${Math.sin(angle)*velocity}px) scale(0)`, opacity: 0 }
                ], { duration: 800, easing: 'cubic-bezier(0, .9, .57, 1)' }).onfinish = () => spark.remove();
            }
        });
    </script>
</body>
</html>
