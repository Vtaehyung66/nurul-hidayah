<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH | NEURAL CYBER SYSTEM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Engine Particle Neural Link -->
    <script src="https://cdn.jsdelivr.net"></script>
    <style>
        /* Base Cyber Theme */
        body { background: #000c1d; color: #00f2ff; overflow-x: hidden; font-family: 'Courier New', monospace; cursor: crosshair; }
        #particles-js { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }
        
        /* Scanline CRT Effect */
        body::before {
            content: " "; display: block; position: fixed; top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%);
            z-index: 100; background-size: 100% 3px; pointer-events: none;
        }

        /* Bingkai Robotic Percerah (Glow Sharp) */
        .cyber-frame {
            background: rgba(1, 28, 50, 0.85);
            border: 2px solid #00f2ff;
            box-shadow: 0 0 15px rgba(0, 242, 255, 0.4);
            position: relative;
            clip-path: polygon(8% 0, 100% 0, 100% 92%, 92% 100%, 0 100%, 0 8%);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .cyber-frame:hover { 
            box-shadow: 0 0 40px rgba(0, 242, 255, 0.9); 
            transform: translateY(-5px) scale(1.02); 
            background: rgba(1, 40, 70, 0.9);
        }

        /* Animasi Binary 101010 */
        .bin-char {
            position: fixed; color: #00f2ff; font-weight: bold; pointer-events: none;
            text-shadow: 0 0 10px #00f2ff; z-index: 1000; animation: binaryExplode 0.8s ease-out forwards;
        }
        @keyframes binaryExplode {
            0% { transform: translate(0, 0) scale(1.5); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) rotate(360deg) scale(0); opacity: 0; }
        }

        .neon-glow { text-shadow: 0 0 20px #00f2ff, 0 0 5px #00f2ff; }
        .cyber-line { height: 2px; background: linear-gradient(90deg, transparent, #00f2ff, transparent); margin: 25px 0; }
    </style>
</head>
<body onmousedown="createBinaryBurst(event)">
    <!-- Particle Background (Neural Connection) -->
    <div id="particles-js"></div>

    <div class="container mx-auto px-6 py-10 relative z-50">
        
        <!-- HEADER (Logo & Map Link) -->
        <header class="flex justify-between items-start mb-12">
            <div class="w-16 h-24 cyber-frame flex items-center justify-center opacity-70">
                <span class="text-[8px] text-center font-bold">PALESTINE<br>MAP_LINK</span>
            </div>
            <div class="text-right">
                <h1 class="text-5xl font-black neon-glow tracking-widest uppercase italic">NURUL HIDAYAH SCHOOL</h1>
                <div class="cyber-line"></div>
            </div>
        </header>

        <!-- BINGKAI FOTO BESAR (Dokumentasi Murid) -->
        <div class="cyber-frame p-2 mb-20 mx-auto max-w-5xl">
            <div class="bg-cyan-950 h-96 flex items-center justify-center overflow-hidden relative">
                <div class="absolute inset-0 bg-[url('https://source.unsplash.com')] bg-cover opacity-50"></div>
                <div class="relative z-10 border-4 border-cyan-400 p-10 backdrop-blur-md">
                    <span class="text-lg tracking-[0.6em] font-black uppercase animate-pulse neon-glow">DOKUMENTASI MURID: ACTIVE</span>
                </div>
            </div>
        </div>

        <!-- 8 BINGKAI KECIL (Foto-foto Guru & Nama) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-24">
            <script>
                const staff = [
                    {n: "IMAT JUNAEDAH.SPDI", r: "KEPALA SEKOLAH/PENGLOLA"},
                    {n: "ATANG ABDURAHMAN", r: "MANAGER/PENGELOLA"},
                    {n: "MASPUPAH.SPD", r: "GURU/SEKERTARIS"},
                    {n: "APIPULLOH ASHIDIQ.S.TI", r: "OPERATOR"},
                    {n: "SRI INDAH", r: "GURU"},
                    {n: "NABILA FAUZAIAH", r: "GURU"},
                    {n: "SALWA NOVIYANTI", r: "GURU"},
                    {n: "STAFF_ACTIVE", r: "GURU"}
                ];
                staff.forEach(s => {
                    document.write(`
                        <div class="group">
                            <div class="cyber-frame p-2 mb-3">
                                <div class="bg-cyan-900/40 h-40 flex items-center justify-center border border-cyan-500/50 overflow-hidden">
                                     <img src="https://api.dicebear.com{s.n}" class="w-24 h-24 opacity-80 group-hover:scale-125 transition duration-500">
                                </div>
                            </div>
                            <div class="bg-cyan-500 text-black text-[9px] font-black py-2 tracking-widest text-center uppercase h-12 flex flex-col justify-center shadow-[0_0_10px_#00f2ff]">
                                <span>${s.n}</span>
                                <span class="text-[7px] opacity-80 mt-1">${s.r}</span>
                            </div>
                        </div>
                    `);
                });
            </script>
        </div>

        <!-- VISI & MISI (LENGKAP SESUAI KETERANGAN) -->
        <div class="grid md:grid-cols-2 gap-10 mb-24">
            <!-- 1. KB NURUL HIDAYAH -->
            <div class="cyber-frame p-8 border-l-8 border-cyan-400 bg-cyan-950/20">
                <h3 class="text-2xl font-black mb-6 italic underline decoration-cyan-400">1. KB NURUL HIDAYAH (PAUD)</h3>
                <div class="text-[11px] space-y-4 opacity-90 leading-relaxed text-cyan-50">
                    <p class="font-bold text-cyan-400 bg-cyan-900/50 p-2 border-r-4 border-cyan-500">"Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap perkembangan teknologi sejak usia dini."</p>
                    <p>• PENDIDIKAN AGAMA ISLAM (PAI): Internalisasi nilai Islami & pembiasaan akhlakul karimah melalui metode fun learning.</p>
                    <p>• PENGENALAN TEKNOLOGI: Multimedia Interaktif sebagai media stimulasi kognitif dan literasi digital aman.</p>
                    <p>• METODE GABUNGAN: Implementasi kurikulum berbasis TIK untuk visualisasi konsep spiritual menjadi pengalaman nyata.</p>
                    <p>• PROFIL PENDIDIK: Kompeten dalam mensinergikan kecerdasan intelektual, emosional, dan spiritual anak.</p>
                    <p>• TUJUAN: Terwujudnya anak didik yang cerdas, kreatif, mandiri, beriman, dan bertaqwa sejak dini.</p>
                </div>
            </div>
            <!-- 2. MADRASAH DINIYAH -->
            <div class="cyber-frame p-8 border-r-8 border-cyan-400 bg-cyan-950/20">
                <h3 class="text-2xl font-black mb-6 italic underline decoration-cyan-400">2. MADRASAH DINIYAH (MD)</h3>
                <div class="text-[11px] space-y-4 opacity-90 leading-relaxed text-cyan-50">
                    <p class="font-bold text-cyan-400 bg-cyan-900/50 p-2 border-l-4 border-cyan-500">"Pendidikan Islam Rahmatan lil 'Alamiin melalui penguasaan disiplin ilmu agama dan pembentukan karakter (Adab)."</p>
                    <p>• KURIKULUM: Tarbiyah/Ta'lim/Ta'dib fokus pada disiplin ilmu keislaman (Ulumuddin) secara mendalam.</p>
                    <p>• LINGKUNGAN: Islamic Environment yang mendukung pengembangan potensi diri berbasis nilai-nilai Islam.</p>
                    <p>• PEDAGOGIK: Keterampilan mengajar efektif dengan penguasaan materi agama secara profesional.</p>
                    <p>• AKHLAKUL KARIMAH: Pembentukan karakter mulia yang menjadi teladan (Uswah) utama bagi masyarakat.</p>
                    <p>• INTEGRITAS: Profesionalisme tinggi berbasis nilai keislaman dan tanggung jawab moral.</p>
                </div>
            </div>
        </div>

        <!-- SEJARAH PENDIRIAN (Center Denah) -->
        <div class="max-w-4xl mx-auto text-center mb-24">
            <h2 class="text-4xl font-black tracking-[0.4em] uppercase mb-1 neon-glow">SEJARAH PENDIRIAN</h2>
            <p class="text-[10px] tracking-[0.2em] text-cyan-500 mb-10 italic">NURUL HIDAYAH SCHOOL GENESIS INFRASTRUCTURE</p>
            
            <div class="cyber-frame w-64 h-64 mx-auto mb-6 p-4 flex items-center justify-center">
                <div class="border-2 border-dashed border-cyan-500 w-full h-full flex flex-col items-center justify-center opacity-60">
                    <span class="text-[12px] font-bold">KH. MUSTOFA.MUI</span>
                    <span class="text-[8px] uppercase tracking-widest mt-2">[ FOTO PENDIRI ]</span>
                </div>
            </div>
            <div class="text-cyan-400 text-xs font-black tracking-[0.5em] mb-12 underline">FOTO PENDIRI</div>

            <div class="text-center">
                <h4 class="text-sm font-bold text-cyan-300 mb-6 tracking-[0.4em] uppercase">[ KETERANGAN SEJARAH ]</h4>
                <div class="cyber-frame p-10 text-[12px] leading-relaxed text-justify italic bg-cyan-900/10 border-t-8 border-cyan-500 shadow-[0_-10px_20px_rgba(0,242,255,0.2)]">
                    "Ponpes Nurul Hidayah didirikan dengan sebuah tekad mulia: memberikan akses pendidikan berkualitas yang mampu menyinergikan kecerdasan intelektual dan kedalaman spiritual. Berawal dari visi sederhana seorang tokoh ulama Indonesia KH. MUSTOFA, yang peduli terhadap masa depan generasi muda, sekolah ini tumbuh dari langkah-langkah kecil yang penuh perjuangan. Melalui komitmen kuat dari para pendiri, dukungan guru-guru yang berdedikasi, serta kepercayaan penuh dari masyarakat, Nurul Hidayah kini terus berkembang menjadi institusi yang tidak hanya mengajarkan ilmu pengetahuan, tetapi juga membentuk karakter. Beliau percaya bahwa setiap anak adalah amanah, dan sejarah kami adalah perjalanan panjang dalam menjaga amanah tersebut untuk generasi yang lebih baik."
                </div>
            </div>
        </div>

        <!-- FOOTER HEXAGON DECOR -->
        <footer class="flex justify-center opacity-30 pb-16">
            <div class="w-12 h-12 border-2 border-cyan-500 rotate-45"></div>
            <div class="w-12 h-12 border-2 border-cyan-500 rotate-45 mx-6"></div>
            <div class="w-12 h-12 border-2 border-cyan-500 rotate-45"></div>
        </footer>
    </div>

    <script>
        // Particle Engine (Mirip gambar: Bulat-bulat saling nyambung & gerak sendiri)
        particlesJS("particles-js", {
            "particles": {
                "number": { "value": 110, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#00f2ff" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.6, "random": true },
                "size": { "value": 4, "random": true },
                "line_linked": { "enable": true, "distance": 160, "color": "#00f2ff", "opacity": 0.4, "width": 1.5 },
                "move": { "enable": true, "speed": 2.5, "direction": "none", "out_mode": "out" }
            },
            "interactivity": { "events": { "onhover": { "enable": true, "mode": "grab" } } }
        });

        // Binary 101010 Burst (Efek pas ditekan/klik)
        function createBinaryBurst(e) {
            for(let i=0; i<15; i++) {
                const b = document.createElement('div');
                b.className = 'bin-char';
                b.innerText = Math.random() > 0.5 ? "1" : "0";
                const tx = (Math.random() - 0.5) * 350 + "px";
                const ty = (Math.random() - 0.5) * 350 + "px";
                b.style.setProperty('--tx', tx);
                b.style.setProperty('--ty', ty);
                b.style.left = e.clientX + "px";
                b.style.top = e.clientY + "px";
                document.body.appendChild(b);
                setTimeout(() => b.remove(), 800);
            }
        }
    </script>
</body>
</html>