 pendidikan, pengajaran, adab. Fokus utama pembentukan karakter uswah hasanah.</p> </div> </div> <!-- 8 BINGKAI GURU (foto kecil + nama) nuansa light blue --> <div style="margin: 35px 0 10px; color:#9ae2ff; font-size:2rem; text-shadow:0 0 15px cyan;">⚡ PENDIDIK & TENAGA AHLI ⚡</div> <div class="teacher-grid"> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%233ecfff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%230066aa%22/></svg>')"></div><div class="teacher-name">imat junaedah.sPd.i</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%236ad4ff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23004499%22/></svg>')"></div><div class="teacher-name">atang abdurahman</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%235ec8ff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%230055aa%22/></svg>')"></div><div class="teacher-name">maspupah.spd</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%234ab5ff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23003388%22/></svg>')"></div><div class="teacher-name">apipulloh ashidiq.s.ti</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%237fd4ff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23004488%22/></svg>')"></div><div class="teacher-name">sri indah</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%233db5ff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23002277%22/></svg>')"></div><div class="teacher-name">nabila fauziah</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%2362ccff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23004c99%22/></svg>')"></div><div class="teacher-name">salwa noviyanti</div></div> <div class="teacher-card"><div class="photo-frame" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2240%22 r=%2230%22 fill=%22%2380ddff%22/><rect x=%2230%22 y=%2265%22 width=%2240%22 height=%2235%22 fill=%22%23001a6b%22/></svg>')"></div><div class="teacher-name">KH. mustofa.mui</div></div> </div> <!-- BINGKAI BESAR DOKUMENTASI MURID (light blue) --> <div class="big-docu-frame robotic-frame" style="padding:20px;"> <div class="big-photo"></div> <div class="big-caption">📷 BINGKAI FOTO BESAR – DOKUMENTASI MURID</div> </div> <!-- Footer pendiri dengan deskripsi --> <div class="pendiri-footer"> <span>pendiri: kh.mustofa.mui</span> <span style="font-size:1.1rem; max-width:600px;">🌐 ponpes Nurul Hidayah didirikan dengan tekad mulia: sinergi intelektual & spiritual. Berawal dari langkah kecil KH. Mustofa, tumbuh menjadi institusi pembentuk karakter. Beliau percaya setiap anak adalah amanah. 🌐</span> </div> <!-- pengulangan kecil teks bawah (mirip foto) --> <div style="display:flex; gap:15px; margin-top:40px; color:#b0ebff; border-top:2px solid #6ae9ff; padding:18px;"> <div style="flex:1;">Nurul bidayah fahol orooing on professional, child centric. changting professional, education.</div> <div style="flex:1;">Child-centric: fousen menghamilinkan dengan alaudalico disciilan...</div> </div> </div> <!-- partikel + garis sambung light blue --> <script> (function() { const container = document.getElementById('particles'); const particleCount = 42; const particles = []; for (let i = 0; i < particleCount; i++) { const p = document.createElement('div'); p.className = 'particle'; const x = Math.random() * 100; const y = Math.random() * 100; p.style.left = x + '%'; p.style.top = y + '%'; p.style.animationDelay = (i * 0.15) + 's'; p.style.width = (Math.random() * 15 + 5) + 'px'; p.style.height = p.style.width; container.appendChild(p); particles.push({ el: p, x, y }); } function drawConnections() { const threshold = 13; for (let i = 0; i < particles.length; i++) { for (let j = i + 1; j < particles.length; j++) { const dx = particles[i].x - particles[j].x; const dy = particles[i].y - particles[j].y; const dist = Math.sqrt(dx*dx + dy*dy); if (dist < threshold) { const line = document.createElement('div'); line.className = 'connector'; const x1 = particles[i].x, y1 = particles[i].y; const x2 = particles[j].x, y2 = particles[j].y; const length = Math.sqrt((x2-x1)**2 + (y2-y1)**2) * window.innerWidth / 100; const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI; line.style.width = length + 'px'; line.style.left = x1 + '%'; line.style.top = y1 + '%'; line.style.transform = `rotate(${angle}deg)`; line.style.background = 'linear-gradient(90deg, #5ee2ff, #aadcff, #5ee2ff)'; container.appendChild(line); } } } } window.addEventListener('load', ()=>{ drawConnections(); }); setTimeout(drawConnections, 120); })(); </script> <!-- efek tekan binary manual untuk semua kartu --> <script> document.querySelectorAll('.teacher-card, .document-card, .vm-block, .big-docu-frame').forEach(el => { el.addEventListener('mousedown', (e) => { const bin = document.createElement('div'); bin.innerText = '1010101'; bin.style.position = 'absolute'; bin.style.left = e.pageX + 'px'; bin.style.top = e.pageY + 'px'; bin.style.color = '#9ae2ff'; bin.style.fontSize = '30px'; bin.style.fontWeight = 'bold'; bin.style.opacity = '0.8'; bin.style.pointerEvents = 'none'; bin.style.zIndex = '9999'; bin.style.fontFamily = 'monospace'; bin.style.textShadow = '0 0 15px cyan'; document.body.appendChild(bin); setTimeout(() => bin.remove(), 650); }); }); </script></body> </html> ```