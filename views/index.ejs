<!DOCTYPE html><html lang="en"> <head> <meta charset="UTF-8"> <meta name="viewport" content="width=device-width, initial-scale=1.0"> <title>NURUL HIDAYAH – cyber light blue system</title> <style> * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif; }
body {
min-height: 100vh;
background: radial-gradient(circle at 30% 40%, #0a1928, #030614 95%);
display: flex;
justify-content: center;
align-items: center;
padding: 20px;
position: relative;
overflow-x: auto;
}

/* === background partikel light blue, menyambung, bergerak === */
.cyber-particles {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
pointer-events: none;
z-index: 0;
}

.particle {
position: absolute;
width: 8px;
height: 8px;
background: #6ae9ff;
border-radius: 50%;
box-shadow: 0 0 25px #3ecfff, 0 0 60px #00b8ff;
animation: floatLight 22s infinite alternate ease-in-out;
}

.connector {
position: absolute;
height: 2px;
background: linear-gradient(90deg, #4dc3ff, #a0e0ff, #4dc3ff);
opacity: 0.35;
transform-origin: 0 0;
border-radius: 4px;
box-shadow: 0 0 20px #3ecfff;
animation: flickerBlue 10s infinite;
}

@keyframes floatLight {
0% { transform: translate(0, 0) scale(1); opacity: 0.5; }
100% { transform: translate(45px, -35px) scale(2); opacity: 1; }
}

@keyframes flickerBlue {
0% { opacity: 0.2; }
50% { opacity: 0.8; }
100% { opacity: 0.2; }
}

.binary-overlay {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
background: repeating-linear-gradient(45deg,
rgba(100, 230, 255, 0.03) 0px,
rgba(0, 50, 70, 0) 50px);
pointer-events: none;
z-index: 1;
}

/* ===== CARD UTAMA LIGHT BLUE DOMINAN ===== */
.document-card {
max-width: 1250px;
width: 100%;
background: rgba(8, 28, 45, 0.7);
backdrop-filter: blur(5px);
-webkit-backdrop-filter: blur(5px);
border: 2px solid #6ae9ff;
box-shadow: 0 0 50px #00c8ff, 0 0 20px #0077ff inset;
padding: 30px 25px;
border-radius: 40px;
position: relative;
z-index: 10;
transition: box-shadow 0.2s;
}

/* efek tekan binary 1010101 light blue */
.document-card:active::after {
content: "1010101 011001 101010 110011";
position: absolute;
bottom: 15px;
right: 25px;
font-size: 28px;
font-weight: bold;
color: #9cebff;
opacity: 0.4;
white-space: pre;
font-family: 'Courier New', monospace;
pointer-events: none;
animation: binaryGlow 0.7s;
text-shadow: 0 0 20px cyan;
}

@keyframes binaryGlow {
0% { opacity: 0.8; transform: scale(1.3); }
100% { opacity: 0; transform: scale(1); }
}

/* semua bingkai menggunakan light blue robotic glow */
.robotic-frame {
border: 2px solid #5ee2ff;
border-radius: 28px;
box-shadow: 0 0 35px #3ecfff, 0 0 80px #007bff, inset 0 0 15px #8af0ff;
background: rgba(12, 35, 50, 0.6);
backdrop-filter: blur(4px);
padding: 14px;
transition: 0.2s;
}

.robotic-frame:hover {
box-shadow: 0 0 50px #00e0ff, 0 0 110px #0044ff, inset 0 0 25px #b5ffff;
border-color: #b0f0ff;
}

/* TYPOGRAPHY */
.main-title {
font-size: 3.8rem;
font-weight: 800;
text-align: center;
color: #c2f2ff;
text-shadow: 0 0 20px #0af, 0 0 45px #6bb5ff;
letter-spacing: 5px;
margin-bottom: 5px;
}

.subhead-fazil {
font-size: 2.2rem;
color: #b3ecff;
text-align: center;
border-bottom: 2px dashed #5ee2ff;
padding-bottom: 8px;
margin-bottom: 30px;
text-transform: uppercase;
font-weight: 400;
text-shadow: 0 0 12px #0af;
}

.row-flex {
display: flex;
gap: 25px;
flex-wrap: wrap;
}

.left-names {
flex: 1.2;
min-width: 280px;
}

.right-history {
flex: 2;
min-width: 340px;
}

.name-block {
background: #082433cc;
border: 2px solid #6ae9ff;
border-radius: 32px;
padding: 25px 20px;
box-shadow: 0 0 40px #1eb2ff;
}

.name-item {
font-size: 1.8rem;
font-weight: 600;
color: #c2f5ff;
margin: 18px 0;
display: flex;
align-items: center;
gap: 15px;
border-left: 5px solid #6ae9ff;
padding-left: 20px;
text-shadow: 0 0 10px #7fc9ff;
}

.name-item small {
font-size: 1.1rem;
color: #a2dcff;
font-weight: 300;
}

.bullet-list {
color: #bee6ff;
font-size: 1.15rem;
line-height: 1.6;
margin-top: 18px;
}

.bullet-list p {
margin: 15px 0;
border-bottom: 1px solid #3ecfff40;
padding-bottom: 6px;
}

/* SEJARAH */
.history-section {
background: #0b2637d9;
border-radius: 40px;
padding: 25px;
border: 2px solid #5ee2ff;
box-shadow: 0 0 45px #00b7ff, inset 0 0 20px #8ecfff;
}

.history-title {
font-size: 2.5rem;
font-weight: bold;
color: #d2f2ff;
text-shadow: 0 0 15px #00c3ff;
margin-bottom: 8px;
}

.foto-pendiri {
display: flex;
align-items: center;
gap: 30px;
margin: 30px 0;
background: #0d3448;
padding: 20px;
border-radius: 60px;
border: 2px solid #6ae9ff;
box-shadow: 0 0 40px #3ecfff;
}

.foto-placeholder {
width: 150px;
height: 150px;
background: linear-gradient(145deg, #3ecfff, #004c99);
border-radius: 50%;
border: 4px solid #b5ffff;
box-shadow: 0 0 70px #3ecfff;
display: flex;
align-items: center;
justify-content: center;
font-weight: bold;
color: white;
background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22 fill=%22%236ae9ff%22><circle cx=%2250%22 cy=%2250%22 r=%2245%22 fill=%22%23004488%22/><text x=%2222%22 y=%2270%22 font-size=%2236%22 fill=%22%23e0ffff%22 font-family=%22Arial%22>KH</text></svg>');
background-size: cover;
}

.keterangan-sejarah {
color: #c2edff;
font-size: 1.2rem;
line-height: 1.6;
background: #0d2c40;
padding: 20px;
border-radius: 40px;
border: 1px solid #5ee2ff;
}

/* VISI MISI DUAL */
.visi-misi-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 25px;
margin: 45px 0 35px;
}

.vm-block {
background: #0f2f41ee;
border: 2px solid #6ae9ff;
border-radius: 48px;
padding: 28px 22px;
box-shadow: 0 0 40px #1eb2ff, inset 0 0 15px #9ae2ff;
}

.vm-title {
font-size: 2rem;
color: #baeaff;
border-bottom: 3px dotted #6ae9ff;
padding-bottom: 8px;
margin-bottom: 22px;
}

/* 8 GURU FRAME */
.teacher-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 22px;
margin: 50px 0 30px;
}

.teacher-card {
background: #0b2637;
border: 3px solid #5ee2ff;
border-radius: 48px;
padding: 18px 10px 12px 10px;
text-align: center;
box-shadow: 0 0 45px #3ecfff, 0 0 90px #004c99;
transition: 0.15s;
}

.teacher-card:active {
transform: scale(0.97);
}

.teacher-card:active::after {
content: "1010101";
font-family: monospace;
font-size: 32px;
color: #8ed3ff;
opacity: 0.35;
position: relative;
top: -15px;
}

.photo-frame {
width: 100%;
aspect-ratio: 1/1.1;
background: linear-gradient(145deg, #6ae9ff, #004cbf);
border-radius: 40px;
margin-bottom: 12px;
border: 3px solid #b0f0ff;
box-shadow: 0 0 40px #00b0ff;
background-size: cover;
background-position: center;
}

.teacher-name {
font-size: 1.15rem;
font-weight: 600;
color: #e2f7ff;
background: #0f3145;
padding: 8px 3px;
border-radius: 50px;
border: 1px solid #6ae9ff;
margin-top: 10px;
text-shadow: 0 0 5px #6ae9ff;
}

/* big doc */
.big-docu-frame {
margin: 40px 0 25px;
text-align: center;
}

.big-photo {
max-width: 100%;
height: 220px;
background: linear-gradient(90deg, #6ae9ff, #1e90ff, #6ae9ff);
border-radius: 100px;
border: 4px solid #b5ffff;
box-shadow: 0 0 100px #00c8ff;
display: flex;
align-items: center;
justify-content: center;
color: #021c28;
font-size: 2.5rem;
font-weight: bold;
background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 150%22 fill=%22%236ae9ff%22><rect width=%22400%22 height=%22150%22 fill=%22%23003466%22/><circle cx=%22100%22 cy=%2275%22 r=%2230%22 fill=%22%236ae9ff%22/><circle cx=%22260%22 cy=%2275%22 r=%2230%22 fill=%22%2390d0ff%22/><text x=%22150%22 y=%22110%22 fill=%22%23ffffff%22 font-size=%2232%22>📸 MURID</text></svg>');
background-size: cover;
}

.big-caption {
margin-top: 15px;
color: #aae6ff;
font-size: 1.9rem;
text-transform: uppercase;
text-shadow: 0 0 10px cyan;
}

.pendiri-footer {
display: flex;
justify-content: space-between;
align-items: center;
background: #0b314a;
border-radius: 70px;
padding: 18px 35px;
border: 2px solid #6ae9ff;
margin-top: 30px;
font-size: 1.6rem;
font-weight: 600;
color: #d0f0ff;
box-shadow: 0 0 40px #00b0ff;
}

/* light blue all over */
.pendiri-footer span {
text-shadow: 0 0 8px #6ae9ff;
}
</style>

