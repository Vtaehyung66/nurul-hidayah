<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH | Digital Excellence</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --neon-blue: #00f2ff;
            --ibm-blue: #001d6c;
        }

        /* BACKGROUND GRADASI SESUAI PERMINTAAN */
        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background: linear-gradient(180deg, #ffffff 0%, #87ceeb 45%, var(--ibm-blue) 100%);
            background-attachment: fixed;
            min-height: 100vh;
            overflow-x: hidden;
            color: #161616;
        }

        /* UNIFORM GLASS FRAME (Sama seperti efek Legacy & Vision di foto) */
        .glass-frame {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 
                        inset 0 0 15px rgba(255, 255, 255, 0.5);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            position: relative;
            z-index: 10;
        }

        /* EFEK NEON GLOW SAAT HOVER (Sesuai Foto) */
        .glass-frame:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: var(--neon-blue);
            box-shadow: 0 0 25px rgba(0, 242, 255, 0.4), 
                        0 20px 40px rgba(0, 0, 0, 0.2);
        }

        /* SISTEM PERCIKAN LISTRIK (SPARKS) */
        .spark-container {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 9999;
        }

        .spark {
            position: absolute;
            width: 4px; height: 4px;
            background: var(--neon-blue);
            border-radius: 50%;
            box-shadow: 0 0 15px var(--neon-blue), 0 0 5px white;
        }

        .title-huge {
            font-family: 'Orbitron', sans-serif;
            color: #002d9c;
            text-shadow: 2px 2px 20px rgba(255, 255, 255, 0.8);
        }

        .floating { animation: float 4s ease-in-out infinite; }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }
    </style>
</head>
<body class="antialiased">

    <div class="spark-container" id="spark-container"></div>

    <header class="pt-24 pb-12 px-6 text-center">
        <div data-aos="fade-down" class="mb-8">
            <span class="px-6 py-3 bg-blue-900 text-white text-[10px] tracking-[0.5em] uppercase font-bold rounded-sm shadow-xl floating inline-block">
                Pendidikan Berbasis agama islam, formal & Teknologi
            </span>
        </div>
        
        <h1 class="title-huge text-6xl md:text-9xl font-extrabold mb-16 tracking-tighter" data-aos="zoom-in">
            NURUL HIDAYAH
        </h1>

        <!-- MEGA HERO FRAME (Efek Disamakan) -->
        <div class="max-w-7xl mx-auto px-4 mb-28" data-aos="fade-up">
            <div class="glass-frame p-3 rounded-lg overflow-hidden">
                <div class="aspect-[21/9] relative rounded-md overflow-hidden bg-white/20">
                    <img src="https://images.unsplash.com" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-blue-900/60 to-transparent"></div>
                    <div class="absolute bottom-10 left-10 text-left text-white">
                        <p class="font-bold text-2xl md:text-4xl tracking-tight">MAIN_ARCHIVE_DIGITAL</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 space-y-40 pb-40">

        <!-- 6 DOKUMENTASI (Efek Disamakan) -->
        <section class="grid grid-cols-2 md:grid-cols-3 gap-10">
            <% for(let i=1; i<=6; i++) { %>
            <div class="glass-frame p-2 group" data-aos="fade-up" data-aos-delay="<%= i*100 %>">
                <div class="aspect-video overflow-hidden rounded-sm bg-white/30">
                    <img src="https://picsum.photos<%= i+100 %>/800/450" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-3 text-[9px] font-bold text-blue-900 tracking-widest opacity-60">VISUAL_REC_0<%= i %></div>
            </div>
            <% } %>
        </section>

        <!-- VISI MISI LENGKAP -->
        <section class="grid md:grid-cols-2 gap-12">
            <div class="bg-white/80 backdrop-blur-xl p-10 md:p-16 border-t-8 border-blue-600 shadow-2xl rounded-xl" data-aos="fade-right">
                <h2 class="text-blue-700 font-bold text-xs uppercase tracking-widest mb-6">KB NURUL HIDAYAH</h2>
                <div class="space-y-6 text-sm leading-relaxed text-justify">
                    <p class="text-2xl text-blue-950 font-light italic border-l-4 border-cyan-400 pl-6 bg-blue-50 py-6">"Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap perkembangan teknologi."</p>
                    <p class="font-bold">PAI: Internalisasi nilai Islami melalui metode fun learning.</p>
                    <p>Pengenalan Teknologi: Multimedia interaktif sebagai stimulasi kognitif anak.</p>
                    <div class="bg-blue-100/50 p-6 text-[11px] space-y-2">
                        <p>• Pendidikan Karakter Sejak Dini</p>
                        <p>• Lingkungan Aman & Kondusif</p>
                        <p>• Kemitraan Orang Tua & Sekolah</p>
                    </div>
                </div>
            </div>

            <div class="bg-white/80 backdrop-blur-xl p-10 md:p-16 border-t-8 border-cyan-400 shadow-2xl rounded-xl" data-aos="fade-left">
                <h2 class="text-blue-700 font-bold text-xs uppercase tracking-widest mb-6">MI NURUL HIDAYAH</h2>
                <div class="space-y-6 text-sm leading-relaxed">
                    <div class="p-6 bg-white/50 border border-blue-50">
                        <h4 class="font-bold text-blue-900 mb-2 uppercase text-[10px]">Madrasah Diniyah Takmiliyah</h4>
                        <p>Fokus kurikulum PAI, pembentukan Adab, dan penguasaan ilmu agama mendalam (Ulumuddin).</p>
                    </div>
                    <div class="p-6 bg-white/50 border border-blue-50">
                        <h4 class="font-bold text-blue-900 mb-2 uppercase text-[10px]">Islamic Environment</h4>
                        <p>Lingkungan Rahmatan lil 'Alamiin untuk kedamaian dan pembentukan karakter peserta didik.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 8 BINGKAI GURU (Efek Disamakan) -->
        <section>
            <h2 class="text-center text-4xl font-black text-white mb-20 drop-shadow-2xl uppercase tracking-tighter" data-aos="fade-up">Struktur Pengelola</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
                <% 
                const staff = [
                    {n: "IMAT JUNAEDAH.SPDI", j: "Kepala Sekolah"},
                    {n: "ATANG ABDURAHMAN", j: "Manager"},
                    {n: "MASPUPAH.SPD", j: "Sekertaris"},
                    {n: "APIPULLOH ASHIDIQ.S.TI", j: "Operator"},
                    {n: "SRI INDAH", j: "Guru"},
                    {n: "NABILA FAUZIAH", j: "Guru"},
                    {n: "SALWA NOVIYANTI", j: "Guru"},
                    {n: "JAJANG NURJAMAN", j: "Bendahara"}
                ];
                staff.forEach((s, i) => { %>
                <div class="text-center group" data-aos="zoom-in" data-aos-delay="<%= i*50 %>">
                    <div class="glass-frame p-3 aspect-square rounded-full mb-6 flex items-center justify-center">
                        <div class="w-full h-full rounded-full bg-slate-100 flex items-center justify-center text-blue-200">
                             <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z""")/>></svg>
                        </div>
                    </div>
                    <h4 class="text-[11px] font-bold text-white uppercase tracking-wider"><%= s.n %></h4>
                    <p class="text-[8px] text-white/50 font-bold uppercase mt-2 tracking-widest"><%= s.j %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <!-- LEGACY & VISION (BAGIAN PALESTINA/BAWAH SESUAI FOTO) -->
        <section class="glass-frame p-16 md:p-24 rounded-3xl overflow-hidden" data-aos="fade-up">
            <div class="grid md:grid-cols-12 gap-16 items-center">
                <div class="md:col-span-4 text-center">
                    <div class="glass-frame p-3 rotate-3 bg-white">
                        <div class="aspect-[3/4] bg-slate-100 flex items-center justify-center italic text-slate-300 text-[10px] font-bold">FOUNDER_PHOTO</div>
                    </div>
                    <h3 class="mt-8 text-2xl font-bold text-blue-950 uppercase tracking-tight">KH. MUSTOFA.MUI</h3>
                </div>
                <div class="md:col-span-8 text-xl font-light text-gray-700 leading-loose space-y-6">
                    <h2 class="text-5xl font-black text-blue-950 mb-10 tracking-tighter">Legacy & Vision</h2>
                    <p class="text-justify">"Ponpes Nurul Hidayah didirikan dengan tekad mulia KH. MUSTOFA untuk menyinergikan kecerdasan intelektual dan spiritual generasi muda Indonesia."</p>
                    <p class="text-justify italic border-l-4 border-cyan-400 pl-6">"Setiap anak adalah amanah, dan sejarah kami adalah perjalanan panjang menjaga amanah tersebut."</p>
                </div>
            </div>
        </section>

    </main>

    <script src="https://unpkg.com"></script>
    <script>
        AOS.init({ duration: 1000, once: true });

        // SISTEM PERCIKAN LISTRIK (SPARKS) YANG DIPERKUAT
        document.addEventListener('mousedown', (e) => {
            const container = document.getElementById('spark-container');
            for(let i=0; i<15; i++) {
                createSpark(e.clientX, e.clientY, container);
            }
        });

        function createSpark(x, y, container) {
            const spark = document.createElement('div');
            spark.className = 'spark';
            
            // Randomize spark
            const size = Math.random() * 4 + 2;
            spark.style.width = size + 'px';
            spark.style.height = size + 'px';
            spark.style.left = x + 'px';
            spark.style.top = y + 'px';
            
            container.appendChild(spark);

            const angle = Math.random() * Math.PI * 2;
            const velocity = Math.random() * 150 + 50;
            const destX = Math.cos(angle) * velocity;
            const destY = Math.sin(angle) * velocity;

            spark.animate([
                { transform: 'translate(0, 0) scale(1)', opacity: 1 },
                { transform: `translate(${destX}px, ${destY}px) scale(0)`, opacity: 0 }
            ], {
                duration: 600 + Math.random() * 400,
                easing: 'cubic-bezier(0, .9, .57, 1)'
            }).onfinish = () => spark.remove();
        }
    </script>
</body>
</html>
