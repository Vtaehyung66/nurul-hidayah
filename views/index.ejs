/* ROOT VARIABLES & RESET */
:root {
    --primary: #00d4ff;
    --secondary: #0f62fe;
    --dark: #02060f;
    --glass: rgba(255, 255, 255, 0.03);
    --border: rgba(0, 212, 255, 0.2);
    --font-main: 'IBM Plex Sans', sans-serif;
    --font-cyber: 'Orbitron', sans-serif;
}

* { box-sizing: border-box; }
body {
    background-color: var(--dark);
    color: #e0e0e0;
    margin: 0; padding: 0;
    font-family: var(--font-main);
    overflow-x: hidden;
}

#particles-js {
    position: fixed; width: 100%; height: 100%; z-index: -1;
}

.main-wrapper {
    max-width: 1200px; margin: 0 auto; padding: 60px 20px;
}

/* HEADER & TITLES */
header { text-align: center; margin-bottom: 60px; }
.cyber-title {
    font-family: var(--font-cyber);
    font-size: 4rem; font-weight: 700;
    letter-spacing: 10px;
    background: linear-gradient(to bottom, #fff 0%, var(--primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
}

.status-bar {
    font-family: var(--font-cyber);
    font-size: 0.8rem; color: var(--primary);
    margin-top: 10px; letter-spacing: 3px;
}

.blinking-dot {
    height: 8px; width: 8px; background-color: var(--primary);
    border-radius: 50%; display: inline-block;
    animation: blink 1s infinite;
}

@keyframes blink { 50% { opacity: 0; } }

/* MAIN FRAME (DOKUMENTASI) */
.hero-frame { margin-bottom: 80px; }
.frame-container {
    position: relative; padding: 15px;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.4);
}

.corner {
    position: absolute; width: 20px; height: 20px;
    border: 3px solid var(--primary);
}
.tl { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
.tr { top: -2px; right: -2px; border-left: 0; border-bottom: 0; }
.bl { bottom: -2px; left: -2px; border-right: 0; border-top: 0; }
.br { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

.scan-laser {
    position: absolute; width: 100%; height: 2px;
    background: var(--primary); top: 0; left: 0;
    box-shadow: 0 0 15px var(--primary);
    animation: scan 5s infinite linear; z-index: 2;
}

@keyframes scan { 0% { top: 0% } 100% { top: 100% } }

.image-wrapper img {
    width: 100%; border-radius: 4px;
    filter: brightness(0.8) contrast(1.2);
}

/* STAFF GRID */
.staff-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 20px; margin: 40px 0 80px;
}

.staff-card {
    background: var(--glass);
    border: 1px solid var(--border);
    padding: 10px; transition: 0.4s;
    backdrop-filter: blur(10px);
}

.staff-card:hover {
    border-color: var(--primary);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
    transform: scale(1.05);
}

.photo-box {
    height: 150px; background: #0a0e1a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 10px; position: relative;
    overflow: hidden;
}

.info-box .name {
    display: block; font-weight: 600; font-size: 0.85rem;
    color: var(--primary); margin-bottom: 5px;
}

.info-box .role {
    display: block; font-size: 0.7rem; color: #888;
    text-transform: uppercase;
}

/* CONTENT BLOCKS */
.section-tag {
    font-family: var(--font-cyber);
    color: var(--primary); font-size: 1.2rem;
    margin-bottom: 20px; border-left: 4px solid var(--primary);
    padding-left: 15px;
}

.glass-panel {
    background: var(--glass);
    border: 1px solid var(--border);
    padding: 40px; border-radius: 4px;
    margin-bottom: 50px;
}

.highlight-text {
    font-size: 1.5rem; color: #fff; font-weight: 600;
    border-bottom: 1px solid var(--border);
    padding-bottom: 15px; margin-bottom: 20px;
}

.cyber-list { list-style: none; padding: 0; }
.cyber-list li {
    margin-bottom: 15px; padding-left: 20px;
    position: relative;
}
.cyber-list li::before {
    content: ">"; position: absolute; left: 0; color: var(--primary);
}

/* HISTORY SECTION */
.founder-area {
    display: flex; gap: 40px; align-items: center;
    margin-top: 30px;
}

.founder-photo-frame {
    width: 300px; text-align: center;
}

.img-placeholder {
    height: 250px; background: #000;
    border: 1px solid var(--primary);
    display: flex; align-items: center; justify-content: center;
    color: var(--primary); font-family: var(--font-cyber);
}

.history-glass {
    flex: 1; padding: 30px;
    border-left: 5px solid var(--primary);
    background: rgba(255, 255, 255, 0.02);
    font-style: italic; line-height: 1.8;
}

/* RESPONSIVE */
@media (max-width: 900px) {
    .staff-grid { grid-template-columns: repeat(2, 1fr); }
    .founder-area { flex-direction: column; }
    .cyber-title { font-size: 2.5rem; }
}
