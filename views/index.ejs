<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NH DIGITAL SCHOOL | Future-Ready</title>
    
    <!-- CSS & Fonts -->
    <link href="https://cdn.jsdelivr.net" rel="stylesheet">
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --cyber-blue: #00f2ff;
            --cyber-deep: #0f172a; /* Warna Navy Modern (Lebih terang dari hitam) */
            --glass: rgba(255, 255, 255, 0.1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f1f5f9; /* Background luar abu-abu sangat muda agar kontras */
            color: #1e293b;
            overflow-x: hidden;
        }

        .mono { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--cyber-blue); }

        /* --- BACKGROUND PARTICLES --- */
        #particles-js {
            position: fixed;
            width: 100%; height: 100%;
            top: 0; left: 0; z-index: 1;
            pointer-events: none;
            opacity: 0.6;
        }

        /* --- NAVBAR --- */
        .navbar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(0, 242, 255, 0.2);
            padding: 15px 0;
            z-index: 1000;
        }
        .navbar-brand { font-weight: 800; color: var(--cyber-blue) !important; }
        .nav-link { color: #cbd5e1 !important; font-weight: 600; font-size: 0.9rem; margin: 0 10px; transition: 0.3s; }
        .nav-link:hover { color: var(--cyber-blue) !important; transform: translateY(-2px); }

        /* --- HERO SECTION --- */
        .hero {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            padding: 140px 0 180px 0;
            color: white;
            position: relative;
            clip-path: ellipse(150% 100% at 50% 0%);
            z-index: 10;
        }

        .search-wrapper {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            padding: 8px; border-radius: 18px;
            display: flex; max-width: 600px;
            margin-top: 35px; border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        .search-wrapper input { background: transparent; border: none; padding: 12px 20px; flex-grow: 1; outline: none; color: white; }
        .search-wrapper button { background: var(--cyber-blue); color: #000; border: none; padding: 12px 25px; border-radius: 12px; font-weight: 700; transition: 0.3s; }
        .search-wrapper button:hover { box-shadow: 0 0 20px var(--cyber-blue); }

        /* --- STATS BERJAJAR --- */
        .stats-row { display: flex; gap: 20px; margin-top: 50px; flex-wrap: wrap; }
        .stat-glass {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 20px 35px; border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            min-width: 170px; transition: 0.4s;
        }
        .stat-glass h2 { font-weight: 800; margin: 0; color: var(--cyber-blue); font-size: 2.2rem; }
        .stat-glass p { font-size: 0.75rem; margin: 0; text-transform: uppercase; font-weight: 700; opacity: 0.8; }

        /* --- MENU BERJAJAR KE KANAN (PROFIL, DLL) --- */
        .menu-section { padding: 120px 0 80px 0; position: relative; z-index: 20; }
        .menu-container {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap; /* Agar rapi di HP */
        }
        .menu-card {
            background: white;
            padding: 30px; border-radius: 24px;
            text-align: center; width: 220px;
            text-decoration: none; color: #1e293b;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }
        .menu-card:hover {
            transform: translateY(-15px);
            border-color: var(--cyber-blue);
            box-shadow: 0 20px 40px rgba(0, 242, 255, 0.15);
        }
        .icon-box { font-size: 2.5rem; color: #0f172a; margin-bottom: 15px; transition: 0.3s; }
        .menu-card:hover .icon-box { color: var(--cyber-blue); transform: scale(1.1); }
        .menu-card span { font-weight: 800; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; }

    </style>
</head>
<body>

    <div id="particles-js"></div>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-cpu me-2"></i> NH DIGITAL SCHOOL</a>
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/">HOME</a></li>
                    <li class="nav-item"><a class="nav-link" href="#profil">PROFIL</a></li>
                    <li class="nav-item"><a class="nav-link" href="#direktori">DIREKTORI</a></li>
                    <li class="nav-item"><a class="nav-link" href="#publikasi">PUBLIKASI</a></li>
                </ul>
            </div>
            <a href="mailto:<%= email %>" class="btn btn-info btn-sm rounded-pill px-4 fw-bold shadow-sm">KONTAK</a>
        </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
        <div class="container" data-aos="fade-right">
            <div class="mono mb-2">> START_SYSTEM --TARGET=NURUL_HIDAYAH</div>
            <h1 class="display-2 fw-bold mb-3">School Nurul Hidayah</h1>
            <p class="lead opacity-75">Kabupaten Tasikmalaya, Jawa Barat | Inovasi Tiada Henti</p>
            
            <form action="#" class="search-wrapper">
                <input type="text" placeholder="Access Database Kunci Pencarian..." required>
                <button type="submit">EXECUTE</button>
            </form>

            <div class="stats-row">
                <div class="stat-glass" data-aos="zoom-in" data-aos-delay="100">
                    <h2>12</h2>
                    <p>DATABASE GURU</p>
                </div>
                <div class="stat-glass" data-aos="zoom-in" data-aos-delay="200">
                    <h2>245</h2>
                    <p>SISWA AKTIF</p>
                </div>
                <div class="stat-glass" data-aos="zoom-in" data-aos-delay="300">
                    <h2>08</h2>
                    <p>NETWORK KOMITE</p>
                </div>
            </div>
        </div>
    </header>

    <!-- MENU BERJAJAR KE KANAN -->
    <section class="menu-section">
        <div class="container">
            <div class="menu-container">
                <a href="#profil" class="menu-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="icon-box"><i class="bi bi-person-badge"></i></div>
                    <span>Profil</span>
                </a>
                <a href="#struktur" class="menu-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="icon-box"><i class="bi bi-diagram-3"></i></div>
                    <span>Struktur</span>
                </a>
                <a href="#security" class="menu-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="icon-box"><i class="bi bi-shield-lock"></i></div>
                    <span>Security</span>
                </a>
                <a href="#kurikulum" class="menu-card" data-aos="fade-up" data-aos-delay="400">
                    <div class="icon-box"><i class="bi bi-code-slash"></i></div>
                    <span>Kurikulum</span>
                </a>
            </div>
        </div>
    </section>

    <footer class="text-center py-5 border-top bg-white">
        <p class="text-muted small fw-bold mb-0">© 2026 <%= nama %> | Built by Solo AI</p>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net"></script>
    <script src="https://unpkg.com"></script>
    <script>
        AOS.init({ duration: 1000, once: true });

        particlesJS('particles-js', {
            "particles": {
                "number": { "value": 60 },
                "color": { "value": "#00f2ff" },
                "line_linked": { "enable": true, "distance": 150, "color": "#00f2ff", "opacity": 0.4, "width": 1 },
                "move": { "enable": true, "speed": 1.5 }
            },
            "interactivity": { "events": { "onhover": { "enable": true, "mode": "grab" } } }
        });
    </script>
</body>
</html>
