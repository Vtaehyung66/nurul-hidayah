<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NH DIGITAL SCHOOL | Cyber Future</title>
    
    <link href="https://cdn.jsdelivr.net" rel="stylesheet">
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --cyber-blue: #00f2ff;
            --cyber-deep: #001220;
            --glass-white: rgba(255, 255, 255, 0.08);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #010409; /* Deep Black Cyber */
            color: #e6edf3;
            overflow-x: hidden;
            margin: 0;
        }

        /* --- BACKGROUND LAYER (BINARY & PARTICLES) --- */
        #particles-js {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0; left: 0;
            z-index: 1;
            pointer-events: none;
            opacity: 0.4;
        }

        .binary-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--cyber-blue);
            opacity: 0.05; /* Sangat transparan agar tidak mencolok */
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }

        /* --- CONTENT WRAPPER --- */
        .main-content { position: relative; z-index: 10; }

        /* --- NAVBAR --- */
        .navbar {
            background: rgba(1, 4, 9, 0.8);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(0, 242, 255, 0.1);
            padding: 15px 0;
        }
        .navbar-brand { font-weight: 800; color: var(--cyber-blue) !important; letter-spacing: -1px; }

        /* --- HERO SECTION --- */
        .hero {
            padding: 120px 0 150px 0;
            position: relative;
            background: radial-gradient(circle at 50% 0%, rgba(0, 242, 255, 0.05) 0%, transparent 70%);
        }

        .mono-tag { font-family: 'JetBrains Mono', monospace; color: var(--cyber-blue); font-size: 0.85rem; }

        /* --- GLASS SEARCH BOX --- */
        .search-wrapper {
            background: var(--glass-white);
            backdrop-filter: blur(10px);
            padding: 8px;
            border-radius: 18px;
            display: flex;
            max-width: 600px;
            margin-top: 35px;
            border: 1px solid rgba(0, 242, 255, 0.2);
            box-shadow: 0 0 30px rgba(0, 242, 255, 0.1);
        }
        .search-wrapper input { background: transparent; border: none; padding: 12px 20px; flex-grow: 1; outline: none; color: white; }
        .search-wrapper button { background: var(--cyber-blue); color: #000; border: none; padding: 12px 25px; border-radius: 12px; font-weight: 700; transition: 0.3s; }
        .search-wrapper button:hover { box-shadow: 0 0 15px var(--cyber-blue); transform: scale(1.05); }

        /* --- STATS ROW BERJAJAR --- */
        .stats-row { display: flex; gap: 20px; margin-top: 50px; flex-wrap: wrap; }
        .stat-glass {
            background: var(--glass-white);
            backdrop-filter: blur(10px);
            padding: 20px 35px;
            border-radius: 20px;
            border: 1px solid rgba(0, 242, 255, 0.1);
            min-width: 170px;
            transition: 0.4s;
        }
        .stat-glass:hover { border-color: var(--cyber-blue); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0, 242, 255, 0.1); }
        .stat-glass h2 { font-weight: 800; margin: 0; color: var(--cyber-blue); font-size: 2rem; }
        .stat-glass p { font-size: 0.75rem; margin: 0; text-transform: uppercase; font-weight: 700; opacity: 0.7; }

        /* --- FEATURE ITEMS --- */
        .features-grid { padding: 100px 0; }
        .feature-item { 
            background: var(--glass-white);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 30px; border-radius: 25px; text-align: center;
            transition: 0.4s; cursor: pointer;
        }
        .feature-item:hover { 
            background: rgba(0, 242, 255, 0.05);
            border-color: var(--cyber-blue);
            transform: translateY(-10px);
        }
        .icon-wrap { font-size: 2.5rem; color: var(--cyber-blue); margin-bottom: 15px; }

    </style>
</head>
<body>

    <!-- LAYER LATAR BELAKANG -->
    <div class="binary-bg" id="binary-rain"></div>
    <div id="particles-js"></div>

    <div class="main-content">
        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" href="#">
                    <i class="bi bi-terminal-fill me-2"></i> NH DIGITAL SCHOOL
                </a>
                <div class="d-none d-lg-block">
                    <span class="mono-tag">// AUTH_SUCCESS: ADMIN_ACTIVE</span>
                </div>
            </div>
        </nav>

        <!-- HERO -->
        <header class="hero">
            <div class="container text-center text-lg-start">
                <div class="row">
                    <div class="col-lg-10" data-aos="fade-up">
                        <div class="mono-tag mb-2">> START_SYSTEM --TARGET=NURUL_HIDAYAH</div>
                        <h1 class="display-2 fw-bold mb-3">School Nurul Hidayah</h1>
                        <p class="lead opacity-75">Kabupaten Tasikmalaya, Jawa Barat | Inovasi Tiada Henti</p>
                        
                        <div class="search-wrapper mx-auto mx-lg-0">
                            <input type="text" placeholder="Access Database Kunci Pencarian...">
                            <button><i class="bi bi-search me-2"></i> EXECUTE</button>
                        </div>

                        <div class="stats-row justify-content-center justify-content-lg-start">
                            <div class="stat-glass" data-aos="zoom-in" data-aos-delay="100">
                                <h2>12</h2>
                                <p>Database Guru</p>
                            </div>
                            <div class="stat-glass" data-aos="zoom-in" data-aos-delay="200">
                                <h2>245</h2>
                                <p>Siswa Aktif</p>
                            </div>
                            <div class="stat-glass" data-aos="zoom-in" data-aos-delay="300">
                                <h2>08</h2>
                                <p>Network Komite</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- ICON GRID -->
        <section class="features-grid">
            <div class="container">
                <div class="row g-4 justify-content-center">
                    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="100">
                        <div class="feature-item">
                            <div class="icon-wrap"><i class="bi bi-cpu"></i></div>
                            <span class="fw-bold">PROFIL</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="200">
                        <div class="feature-item">
                            <div class="icon-wrap"><i class="bi bi-diagram-3"></i></div>
                            <span class="fw-bold">STRUKTUR</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="300">
                        <div class="feature-item">
                            <div class="icon-wrap"><i class="bi bi-shield-lock"></i></div>
                            <span class="fw-bold">SECURITY</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="400">
                        <div class="feature-item">
                            <div class="icon-wrap"><i class="bi bi-code-slash"></i></div>
                            <span class="fw-bold">KURIKULUM</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <footer class="text-center py-5 border-top border-secondary border-opacity-25">
            <p class="mono-tag small mb-0">© 2026 <%= nama %> | ENCRYPTED BY SOLO AI</p>
        </footer>
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net"></script>
    <script src="https://unpkg.com"></script>
    <script>
        // AOS Init
        AOS.init({ duration: 1000, once: true });

        // Binary Rain Effect
        const rainContainer = document.getElementById('binary-rain');
        function createBinary() {
            const binary = document.createElement('div');
            binary.innerText = Math.round(Math.random());
            binary.style.position = 'absolute';
            binary.style.left = Math.random() * 100 + 'vw';
            binary.style.top = '-20px';
            binary.style.animation = `fall ${Math.random() * 3 + 2}s linear infinite`;
            rainContainer.appendChild(binary);
            setTimeout(() => binary.remove(), 5000);
        }
        setInterval(createBinary, 100);

        // Particles JS Config
        particlesJS('particles-js', {
            "particles": {
                "number": { "value": 80 },
                "color": { "value": "#00f2ff" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.5 },
                "size": { "value": 3 },
                "line_linked": { "enable": true, "distance": 150, "color": "#00f2ff", "opacity": 0.4, "width": 1 },
                "move": { "enable": true, "speed": 2 }
            },
            "interactivity": {
                "events": { "onhover": { "enable": true, "mode": "grab" } }
            }
        });
    </script>
    <style>
        @keyframes fall { to { transform: translateY(100vh); } }
    </style>
</body>
</html>
