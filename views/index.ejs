<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH | Ultimate IBM Digital Experience</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    
    <!-- Library Animasi Kelas Berat -->
    <link href="https://unpkg.com" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com"></script>
    <script src="https://cdn.jsdelivr.net"></script>

    <style>
        :root {
            --ibm-blue: #0f62fe;
            --neon-cyan: #00f2ff;
            --deep-navy: #001d6c;
        }

        /* 1. LAYER BACKGROUND GRADASI & GRID */
        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background: linear-gradient(180deg, #ffffff 0%, #87ceeb 45%, var(--deep-navy) 100%);
            background-attachment: fixed;
            color: #161616;
            min-height: 100vh;
            overflow-x: hidden;
            cursor: none; /* Kita gunakan custom magic cursor */
        }

        #particles-js {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.4;
        }

        /* 2. CUSTOM MAGIC CURSOR */
        #magic-cursor {
            position: fixed;
            width: 30px; height: 30px;
            border: 2px solid var(--neon-cyan);
            border-radius: 50%;
            pointer-events: none;
            z-index: 10000;
            transition: transform 0.1s ease;
            mix-blend-mode: difference;
        }

        /* 3. IBM PREMIUM FRAME DENGAN GLASS REFRACTION */
        .ibm-card-ultimate {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
        }

        .ibm-card-ultimate:hover {
            transform: perspective(1200px) rotateY(5deg) rotateX(2deg) translateY(-15px);
            box-shadow: 0 45px 90px rgba(15, 98, 254, 0.2);
            border-color: var(--neon-cyan);
        }

        /* Efek Kilatan Cahaya Berjalan di Kartu */
        .ibm-card-ultimate::before {
            content: "";
            position: absolute;
            top: -100%; left: -100%;
            width: 50%; height: 300%;
            background: linear-gradient(rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
            transform: rotate(45deg);
            transition: all 0.7s;
            pointer-events: none;
        }

        .ibm-card-ultimate:hover::before {
            left: 150%;
        }

        /* 4. TYPOGRAPHY & FX */
        .title-huge {
            font-family: 'Orbitron', sans-serif;
            color: #002d9c;
            letter-spacing: -0.05em;
            filter: drop-shadow(0 10px 20px rgba(0, 45, 156, 0.2));
        }

        .spark {
            position: fixed;
            pointer-events: none;
            background: var(--neon-cyan);
            border-radius: 50%;
            z-index: 10001;
            box-shadow: 0 0 20px var(--neon-cyan);
        }

        /* Animasi Text Glitch Berulang */
        .glitch-text {
            position: relative;
            animation: glitch 5s infinite;
        }

        @keyframes glitch {
            0%, 95%, 100% { transform: translate(0); }
            96% { transform: translate(-2px, 2px); color: var(--neon-cyan); }
            98% { transform: translate(2px, -2px); color: var(--ibm-blue); }
        }

        /* Progress Bar di Atas Layar */
        #scroll-progress {
            position: fixed; top: 0; left: 0; width: 0%; height: 5px;
            background: linear-gradient(90deg, var(--ibm-blue), var(--neon-cyan));
            z-index: 10002;
        }
    </style>
</head>
<body class="antialiased">

    <!-- Layer Background & FX -->
    <div id="particles-js"></div>
    <div id="magic-cursor"></div>
    <div id="scroll-progress"></div>

    <header class="pt-40 pb-20 px-6 text-center relative">
        <div data-aos="fade-down" class="mb-12">
            <span class="px-8 py-3 bg-blue-950 text-white text-[11px] tracking-[0.5em] uppercase font-bold rounded-sm shadow-2xl inline-block border-b-4 border-cyan-400 animate-bounce">
                Pendidikan Berbasis agama islam, formal & Teknologi
            </span>
        </div>
        
        <h1 class="title-huge text-7xl md:text-9xl font-black mb-24 glitch-text" data-aos="zoom-in">
            NURUL <span class="block text-blue-800">HIDAYAH</span>
        </h1>

        <!-- MEGA HERO FRAME -->
        <div class="max-w-7xl mx-auto px-4 mb-48" data-aos="fade-up">
            <div class="ibm-card-ultimate p-4 rounded-2xl shadow-2xl border-4 border-white">
                <div class="aspect-[21/9] relative overflow-hidden rounded-xl">
                    <img src="https://images.unsplash.com" class="w-full h-full object-cover transition-transform duration-2000 hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-blue-950/80 to-transparent"></div>
                    <div class="absolute bottom-12 left-12 text-left">
                        <p class="text-cyan-400 text-xs font-bold tracking-[0.5em] uppercase mb-4 animate-pulse">Live Data Stream: Active</p>
                        <p class="text-white font-bold text-4xl md:text-7xl tracking-tighter uppercase">Primary Archive 01</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 space-y-60 pb-60">

        <!-- 6 DOKUMENTASI (TILT EFFECT) -->
        <section class="grid grid-cols-2 md:grid-cols-3 gap-16">
            <% for(let i=1; i<=6; i++) { %>
            <div class="ibm-card-ultimate p-3 group cursor-pointer" data-aos="flip-left" data-aos-delay="<%= i*100 %>">
                <div class="aspect-video overflow-hidden rounded-lg bg-white">
                    <img src="https://picsum.photos<%= i+120 %>/800/450" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000">
                </div>
                <div class="p-6 flex justify-between items-center">
                    <span class="text-[10px] font-bold text-blue-900 tracking-[0.4em] uppercase">Sector_Data_0<%= i %></span>
                    <div class="flex gap-1">
                        <div class="w-1 h-4 bg-cyan-400 animate-pulse"></div>
                        <div class="w-1 h-4 bg-blue-600 animate-pulse" style="animation-delay: 0.2s"></div>
                    </div>
                </div>
            </div>
            <% } %>
        </section>

        <!-- VISI MISI LENGKAP -->
        <section class="grid md:grid-cols-2 gap-px bg-blue-200 shadow-2xl rounded-[3rem] overflow-hidden border border-blue-100">
            <!-- KB Section -->
            <div class="bg-white p-16 md:p-24 space-y-12" data-aos="fade-right">
                <h2 class="text-blue-600 font-bold text-xs tracking-widest uppercase">Protocol 01: KB NURUL HIDAYAH</h2>
                <h3 class="text-5xl font-black text-blue-950 tracking-tighter">Kelompok Bermain PAUD</h3>
                
                <div class="space-y-10 text-sm text-gray-700 leading-relaxed">
                    <p class="text-2xl text-blue-900 font-light italic border-l-[12px] border-blue-600 pl-12 bg-blue-50 py-12 rounded-r-2xl shadow-inner text-justify">
                        "Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap perkembangan teknologi sejak usia dini."
                    </p>
                    <p class="text-blue-500 font-bold italic">"Menyelenggarakan pendidikan holistik yang mengintegrasikan nilai-nilai Tauhid dengan literasi digital dasar guna membekali anak menghadapi tantangan zaman."</p>
                    
                    <div class="space-y-8 pt-10 border-t border-gray-100">
                        <div>
                            <h4 class="text-blue-900 font-bold uppercase text-[11px] mb-4">Program Inovatif & Modern</h4>
                            <p class="mb-4"><strong>PAI:</strong> Internalisasi nilai Islami melalui <em>Fun Learning</em>.</p>
                            <p><strong>TIK:</strong> Implementasi kurikulum berbasis Teknologi Informasi untuk visualisasi konsep spiritual.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MI Section -->
            <div class="bg-blue-50/50 p-16 md:p-24 space-y-12" data-aos="fade-left">
                <h2 class="text-blue-600 font-bold text-xs tracking-widest uppercase">Protocol 02: MI NURUL HIDAYAH</h2>
                <h3 class="text-5xl font-black text-blue-950 tracking-tighter">Madrasah Ibtidaiyah</h3>

                <div class="space-y-12">
                    <div class="grid gap-8">
                        <div class="ibm-card-ultimate p-10 bg-white border-b-8 border-blue-600 rounded-2xl">
                            <h4 class="font-bold text-blue-900 mb-4 uppercase text-[11px] tracking-widest">Akademik Islam</h4>
                            <p class="text-sm text-gray-600">Tarbiyah, Ta'lim, dan Ta'dib: Fokus utama pada pembentukan Adab dan penguasaan ilmu agama mendalam.</p>
                        </div>
                        <div class="ibm-card-ultimate p-10 bg-white border-b-8 border-cyan-400 rounded-2xl">
                            <h4 class="font-bold text-blue-900 mb-4 uppercase text-[11px] tracking-widest">Global Environment</h4>
                            <p class="text-sm text-gray-600">Menerapkan konsep Rahmatan lil 'Alamiin untuk kedamaian dan karakter peserta didik.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 8 BINGKAI PENGELOLA -->
        <section>
            <div class="text-center mb-24" data-aos="fade-up">
                <h2 class="text-6xl font-black text-blue-950 tracking-tighter uppercase mb-6">Staffing Architecture</h2>
                <div class="h-2 w-48 bg-gradient-to-r from-blue-600 to-cyan-400 mx-auto rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-16">
                <% 
                const staff = [
                    {n: "IMAT JUNAEDAH.SPDI", j: "Kepala Sekolah"},
                    {n: "ATANG ABDURAHMAN", j: "Manager"},
                    {n: "MASPUPAH.SPD", j: "Sekertaris"},
                    {n: "APIPULLOH ASHIDIQ.S.TI", j: "Operator"},
                    {n: "SRI INDAH", j: "Guru"},
                    {n: "NABILA FAUZIAH", j: "Guru"},
                    {n: "SALWA NOVIYANTI", j: "Guru"},
                    {n: "JAJANG NURJAMAN", j: "Bendahara"}
                ];
                staff.forEach((s, i) => { %>
                <div class="text-center group" data-aos="zoom-in" data-aos-delay="<%= i*50 %>">
                    <div class="ibm-card-ultimate p-5 mb-10 aspect-square rounded-full flex items-center justify-center bg-white group-hover:bg-cyan-50">
                        <div class="w-full h-full rounded-full bg-blue-50 flex items-center justify-center text-blue-200">
                             <svg class="w-16 h-16 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z""")/>></svg>
                        </div>
                    </div>
                    <h4 class="font-bold text-[12px] tracking-widest text-blue-950 uppercase mb-2"><%= s.n %></h4>
                    <p class="text-[9px] text-cyan-600 font-bold uppercase tracking-[0.3em] opacity-60"><%= s.j %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <!-- SEJARAH -->
        <section class="ibm-card-ultimate p-24 md:p-36 rounded-[4rem] bg-white/95 shadow-2xl border-b-[16px] border-blue-950" data-aos="fade-up">
            <div class="grid md:grid-cols-12 gap-24 items-center">
                <div class="md:col-span-4 text-center">
                    <div class="ibm-card-ultimate p-4 rotate-3 bg-white shadow-2xl rounded-2xl scale-110">
                        <div class="aspect-[3/4] bg-blue-50 flex items-center justify-center italic text-blue-200 text-xs font-bold tracking-widest uppercase">Archive_Photo</div>
                    </div>
                    <h3 class="mt-16 text-4xl font-black text-blue-950 tracking-tighter uppercase">KH. MUSTOFA.MUI</h3>
                    <p class="text-blue-600 text-xs font-bold tracking-[0.6em] uppercase mt-4">Founder</p>
                </div>

                <div class="md:col-span-8 space-y-12 text-gray-700 leading-loose text-2xl font-light">
                    <h2 class="text-6xl font-black text-blue-950 mb-16 tracking-tighter border-l-[12px] border-blue-600 pl-16">Genesis & Legacy</h2>
                    <p class="text-justify">"Nurul Hidayah didirikan dengan tekad mulia KH. MUSTOFA untuk menyinergikan kecerdasan intelektual dan spiritual generasi muda Indonesia."</p>
                    <div class="p-10 bg-blue-50/50 rounded-2xl border-r-[10px] border-blue-600 shadow-xl">
                        <p class="text-justify italic text-blue-900 font-normal">"Beliau percaya bahwa setiap anak adalah amanah, dan sejarah kami adalah perjalanan panjang menjaga amanah tersebut."</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="py-40 text-center border-t border-blue-100 bg-white/60">
        <p class="font-bold tracking-[1em] text-[11px] text-blue-950 mb-8 uppercase opacity-30">Elite Digital Node — Nurul Hidayah v6.0</p>
        <div class="flex justify-center gap-16 text-[10px] font-black uppercase tracking-[0.6em] text-blue-400">
            <span class="animate-pulse">Islam</span>
            <span class="animate-pulse" style="animation-delay: 0.3s">Formal</span>
            <span class="animate-pulse" style="animation-delay: 0.6s">Technology</span>
        </div>
    </footer>

    <script src="https://unpkg.com"></script>
    <script>
        AOS.init({ duration: 1500, once: true });

        // 1. PARTICLES JS CONFIG
        particlesJS("particles-js", {
            "particles": {
                "number": { "value": 80, "density": { "enable": true, "value_area": 800 } },
                "color": { "value": "#0f62fe" },
                "shape": { "type": "circle" },
                "opacity": { "value": 0.5, "random": true },
                "size": { "value": 3, "random": true },
                "line_linked": { "enable": true, "distance": 150, "color": "#0f62fe", "opacity": 0.4, "width": 1 },
                "move": { "enable": true, "speed": 2 }
            },
            "interactivity": {
                "detect_on": "canvas",
                "events": { "onhover": { "enable": true, "mode": "grab" }, "onclick": { "enable": true, "mode": "push" } }
            }
        });

        // 2. MAGIC CURSOR FOLLOW
        const cursor = document.getElementById('magic-cursor');
        document.addEventListener('mousemove', e => {
            cursor.style.left = e.clientX - 15 + 'px';
            cursor.style.top = e.clientY - 15 + 'px';
        });

        // 3. PROGRESS SCROLL
        window.onscroll = () => {
            let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            let scrolled = (winScroll / height) * 100;
            document.getElementById("scroll-progress").style.width = scrolled + "%";
        };

        // 4. MEGA SPARK CLICK
        document.addEventListener('mousedown', (e) => {
            for(let i=0; i<25; i++) {
                const spark = document.createElement('div');
                spark.className = 'spark';
                const s = Math.random() * 8 + 3;
                spark.style.width = `${s}px`;
                spark.style.height = `${s}px`;
                spark.style.left = `${e.clientX}px`;
                spark.style.top = `${e.clientY}px`;
                document.body.appendChild(spark);

                const angle = Math.random() * Math.PI * 2;
                const velocity = Math.random() * 300 + 50;
                
                spark.animate([
                    { transform: 'translate(0, 0) scale(1)', opacity: 1 },
                    { transform: `translate(${Math.cos(angle)*velocity}px, ${Math.sin(angle)*velocity}px) scale(0)`, opacity: 0 }
                ], { duration: 1000, easing: 'cubic-bezier(0, .9, .57, 1)' }).onfinish = () => spark.remove();
            }
        });
    </script>
</body>
</html>
