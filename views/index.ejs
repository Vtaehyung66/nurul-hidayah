<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= nama %> | Digital Excellence</title>
    
    <!-- CSS & Fonts -->
    <link href="https://cdn.jsdelivr.net" rel="stylesheet">
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">
    <!-- AOS Library untuk Animasi Scroll -->
    <link href="https://unpkg.com" rel="stylesheet">

    <style>
        :root {
            --cyber-blue: #00d2ff;
            --cyber-dark: #001220;
            --main-gradient: linear-gradient(135deg, #0072ff 0%, #00d2ff 100%);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #ffffff;
            overflow-x: hidden;
        }

        .mono { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--cyber-blue); }

        /* --- NAVBAR --- */
        .navbar { background: white; border-bottom: 1px solid #eee; padding: 15px 0; }
        .nav-link { color: #444 !important; font-weight: 600; font-size: 0.9rem; margin: 0 10px; }
        .btn-kontak { background: #0056b3; color: white; border-radius: 8px; padding: 8px 20px; border: none; }

        /* --- HERO SECTION (Sesuai Foto) --- */
        .hero {
            background: var(--main-gradient);
            padding: 80px 0 150px 0;
            color: white;
            position: relative;
            /* Efek Cyber Grid Background */
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 40px 40px;
        }

        .welcome-badge {
            background: rgba(255,255,255,0.2);
            padding: 5px 15px;
            border-radius: 5px;
            font-size: 0.8rem;
            display: inline-block;
            margin-bottom: 20px;
        }

        .hero h1 { font-weight: 800; font-size: 3rem; margin-bottom: 10px; }
        .hero p.location { font-size: 1.5rem; opacity: 0.9; }

        /* Search Bar Sesuai Foto */
        .search-container {
            background: white;
            border-radius: 10px;
            padding: 5px;
            display: flex;
            max-width: 600px;
            margin-top: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .search-container input { border: none; padding: 15px; flex-grow: 1; outline: none; border-radius: 10px 0 0 10px; }
        .search-container select { border: none; border-left: 1px solid #eee; padding: 0 15px; color: #666; outline: none; }
        .search-container button { background: #0056b3; border: none; color: white; padding: 0 30px; border-radius: 8px; font-weight: 600; }

        /* --- STATS BAR --- */
        .stats-bar {
            display: flex;
            gap: 40px;
            margin-top: 50px;
        }
        .stat-item h3 { margin-bottom: 0; font-weight: 800; }
        .stat-item span { font-size: 0.8rem; opacity: 0.8; }

        /* --- FLOATING GO DIGITAL --- */
        .go-digital {
            background: white;
            color: #333;
            padding: 20px;
            border-radius: 15px;
            position: absolute;
            bottom: -50px;
            right: 15%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* --- ICON MENU (Bawah Hero) --- */
        .icon-menu { padding: 100px 0 50px 0; }
        .menu-item { text-align: center; cursor: pointer; transition: 0.3s; }
        .menu-item:hover { transform: translateY(-10px); }
        .icon-circle {
            width: 70px;
            height: 70px;
            background: #f0f5ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            color: #0056b3;
            font-size: 1.5rem;
            transition: 0.3s;
            border: 2px solid transparent;
        }
        .menu-item:hover .icon-circle { background: #0056b3; color: white; box-shadow: 0 0 20px rgba(0,86,179,0.4); border-color: var(--cyber-blue); }
        .menu-item span { font-weight: 700; color: #444; }

    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                <img src="https://upload.wikimedia.org" width="40" class="me-2">
                NH DIGITAL SCHOOL
            </a>
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-link">Home</li>
                    <li class="nav-link">Profil <i class="bi bi-chevron-down small"></i></li>
                    <li class="nav-link">Direktori <i class="bi bi-chevron-down small"></i></li>
                    <li class="nav-link">Publikasi <i class="bi bi-chevron-down small"></i></li>
                </ul>
            </div>
            <button class="btn-kontak">Kontak <i class="bi bi-arrow-right-short"></i></button>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7" data-aos="fade-right">
                    <div class="welcome-badge">Selamat Datang di Website</div>
                    <div class="mono mb-2">// INIT_SYSTEM: NURUL_HIDAYAH_v2.0</div>
                    <h1>School Nurul Hidayah</h1>
                    <p class="location">Kabupaten Tasikmalaya Provinsi Jawa Barat</p>
                    
                    <div class="search-container">
                        <input type="text" placeholder="Masukan Kata Kunci..">
                        <select>
                            <option>Berita</option>
                            <option>Pengumuman</option>
                        </select>
                        <button><i class="bi bi-search me-2"></i> Pencarian</button>
                    </div>

                    <div class="stats-bar">
                        <div class="stat-item">
                            <h3 class="mono">12</h3>
                            <span>Jumlah Guru</span>
                        </div>
                        <div class="stat-item">
                            <h3 class="mono">245</h3>
                            <span>Jumlah Siswa</span>
                        </div>
                        <div class="stat-item">
                            <h3 class="mono">8</h3>
                            <span>Komite Sekolah</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 text-end d-none d-lg-block" data-aos="fade-left">
                    <img src="https://img.freepik.com" class="img-fluid" style="border-radius: 30px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.2));">
                    
                    <!-- Floating Digital Card -->
                    <div class="go-digital" data-aos="zoom-in" data-aos-delay="500">
                        <div class="icon-circle m-0" style="width:50px; height:50px; background:#0056b3; color:white;">
                            <i class="bi bi-cpu"></i>
                        </div>
                        <div class="text-start">
                            <div class="fw-bold">Go Digital</div>
                            <div class="small text-muted">Sekolahku Future-Ready</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ICON MENU -->
    <section class="icon-menu">
        <div class="container">
            <div class="row g-4">
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="100">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-bank"></i></div>
                        <span>Profil</span>
                    </div>
                </div>
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="200">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-diagram-3"></i></div>
                        <span>Struktur</span>
                    </div>
                </div>
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="300">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-people"></i></div>
                        <span>Komite</span>
                    </div>
                </div>
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="400">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-mortarboard"></i></div>
                        <span>Guru</span>
                    </div>
                </div>
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="500">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-person-badge"></i></div>
                        <span>Siswa</span>
                    </div>
                </div>
                <div class="col-4 col-md-2" data-aos="fade-up" data-aos-delay="600">
                    <div class="menu-item">
                        <div class="icon-circle"><i class="bi bi-rss"></i></div>
                        <span>Publikasi</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER SIMPLE -->
    <footer class="text-center py-4 bg-light border-top">
        <p class="text-muted small mb-0">&copy; 2026 <%= nama %> | Digital Transformation Team</p>
    </footer>

    <!-- Scripts -->
    <script src="https://unpkg.com"></script>
    <script>
        // Inisialisasi Animasi Scroll
        AOS.init({
            duration: 1000,
            once: true
        });
    </script>
</body>
</html>

        