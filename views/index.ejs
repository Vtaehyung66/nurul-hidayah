<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NURUL HIDAYAH SCHOOL</title>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <style>
        :root {
            --ibm-blue: #0f62fe;
            --ibm-black: #161616;
            --ibm-gray: #f4f4f4;
            --text-main: #393939;
            --shadow-pop: 0 20px 40px rgba(0,0,0,0.15); /* Efek bayangan menonjol */
        }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            margin: 0; padding: 0;
            color: var(--text-main);
            background-color: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
        }

        .container { max-width: 1300px; margin: 0 auto; padding: 40px 20px; }

        header { text-align: center; padding: 60px 0; }
        h1 { font-size: 3.5rem; font-weight: 700; margin: 0; color: var(--ibm-black); }
        .subtitle { font-size: 1.25rem; color: var(--ibm-blue); margin-top: 10px; }

        /* EFEK MENONJOL UMUM */
        .pop-effect {
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            cursor: pointer;
            border: 1px solid #eee;
        }

        .pop-effect:hover {
            transform: translateY(-10px) scale(1.03); /* Naik dan membesar sedikit */
            box-shadow: var(--shadow-pop);
            border-color: var(--ibm-blue);
            z-index: 10;
        }

        /* 3 BINGKAI DOKUMENTASI BESAR */
        .hero-gallery { display: flex; flex-direction: column; gap: 30px; margin: 40px 0; }
        .frame-large { 
            width: 100%; height: 550px; 
            background: var(--ibm-gray); 
            display: flex; align-items: center; justify-content: center; 
        }

        /* 16 BINGKAI SEDANG BESAR */
        .matrix-grid { 
            display: grid; grid-template-columns: repeat(8, 1fr); 
            gap: 20px; margin: 80px 0; 
        }
        .frame-medium { 
            aspect-ratio: 1/1.1;
            background: #eee;
        }

        /* VISI MISI */
        .section-title { text-align: center; font-size: 2.5rem; margin: 40px 0; border-bottom: 2px solid var(--ibm-blue); display: block; }
        .visi-misi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 80px; }
        .kolom-teks h3 { color: var(--ibm-blue); border-left: 4px solid var(--ibm-blue); padding-left: 15px; margin-bottom: 20px; }

        /* 8 GURU BULAT BESAR */
        .guru-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 50px; margin: 80px 0; text-align: center; }
        .guru-card img { 
            width: 210px; height: 210px; 
            border-radius: 50%; background: var(--ibm-gray); 
            margin-bottom: 15px; object-fit: cover; border: 3px solid #eee;
            transition: all 0.4s ease;
        }
        .guru-card:hover img {
            border-color: var(--ibm-blue);
            transform: scale(1.1) rotate(2deg); /* Efek timbul melingkar */
            box-shadow: var(--shadow-pop);
        }
        .guru-name { font-weight: 600; font-size: 1.2rem; display: block; }

        /* SEJARAH & PENDIRI */
        .history-section { display: grid; grid-template-columns: 400px 1fr; gap: 50px; background: var(--ibm-gray); padding: 60px; margin-top: 80px; border-radius: 8px; }
        .founder-container { text-align: center; }
        .founder-frame { width: 100%; height: 450px; background: #fff; margin-bottom: 15px; overflow: hidden; }
        .history-text { font-size: 1.15rem; text-align: justify; align-self: center; line-height: 1.8; }

        /* ANIMASI SCROLL (FADE IN UP) */
        .animate-on-scroll {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s ease-out;
        }

        .animate-on-scroll.visible {
            opacity: 1;
            transform: translateY(0);
        }

    </style>
</head>
<body>

<div class="container">
    <header class="animate-on-scroll">
        <h1>NURUL HIDAYAH</h1>
        <div class="subtitle">Pendidikan Berbasis agama islam, formal & Teknologi</div>
    </header>

    <!-- 3 BINGKAI DOKUMENTASI BESAR -->
    <section class="hero-gallery">
        <div class="frame-large pop-effect animate-on-scroll"><p>Dokumentasi Utama 1</p></div>
        <div class="frame-large pop-effect animate-on-scroll"><p>Dokumentasi Utama 2</p></div>
        <div class="frame-large pop-effect animate-on-scroll"><p>Dokumentasi Utama 3</p></div>
    </section>

    <!-- MATRIX 16 BINGKAI SEDANG -->
    <div class="matrix-grid">
        <!-- Loop 16 Bingkai dengan efek Pop -->
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
        <div class="frame-medium pop-effect animate-on-scroll"></div>
    </div>

    <!-- VISI MISI -->
    <h2 class="section-title animate-on-scroll">VISI & MISI</h2>
    <section class="visi-misi-grid animate-on-scroll">
        <div class="kolom-teks">
            <h3>1. Sekolah KB NURUL HIDAYAH</h3>
            <p>Lembaga kelompok bermain paud "Membentuk generasi Rabbani yang unggul, berakhlak mulia, dan adaptif terhadap perkembangan teknologi sejak usia dini." "Menyelenggarakan pendidikan holistik yang mengintegrasikan nilai-nilai Tauhid dengan literasi digital dasar guna membekali anak menghadapi tantangan zaman."</p>
            <strong>Program & Karakter:</strong>
            <ul>
                <li>Pendidikan Agama Islam & Literasi Digital Dasar.</li>
                <li>Kurikulum berbasis TIK & Fun Learning.</li>
                <li>Pendidik Kompeten & Fasilitator Digital.</li>
                <li>Pembelajaran Aktif (PAKEM) & Lingkungan Kondusif.</li>
            </ul>
        </div>
        <div class="kolom-teks">
            <h3>2. Sekolah Keagamaan NURUL HIDAYAH</h3>
            <p>Sekolah Madrasah diniyah Akademik dan Kurikulum Keislaman Tarbiyah/Ta'lim/Ta'dib.</p>
            <ul>
                <li>Ulumuddin/Ilmu Keislaman Mendalam.</li>
                <li>Lingkungan Rahmatan lil 'Alamiin.</li>
                <li>Character Development & Akhlakul Karimah.</li>
                <li>Pendidik dengan Kompetensi Pedagogik & Profesional Keilmuan.</li>
            </ul>
        </div>
    </section>

    <!-- 8 GURU BULAT BESAR -->
    <section class="guru-grid">
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Imat Junaedah, S.Pd.I</span><span class="guru-role">Kepala Sekolah</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Atang Abdurahman</span><span class="guru-role">Manager</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Maspupah, S.Pd</span><span class="guru-role">Sekretaris</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Apipulloh Ashidiq, S.TI</span><span class="guru-role">Operator</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Sri Indah</span><span class="guru-role">Guru</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Nabila Fauziah</span><span class="guru-role">Guru</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Salwa Noviyanti</span><span class="guru-role">Guru</span></div>
        <div class="guru-card animate-on-scroll"><img src="" alt="Foto"><span class="guru-name">Jajang Nurjaman</span><span class="guru-role">Bendahara</span></div>
    </section>

    <!-- PENDIRI & SEJARAH -->
    <section class="history-section animate-on-scroll">
        <div class="founder-container">
            <div class="founder-frame pop-effect">
                <img src="" alt="Foto Pendiri" style="width:100%; height:100%; object-fit:cover; background:#ccc;">
            </div>
            <p><strong>Pendiri: KH. AJ. MUSTOFA</strong></p>
        </div>
        <div class="history-text">
            <p>"ponpes Nurul Hidayah didirikan pada tahun 1987 oleh seseorang dengan sebuah tekad mulia: memberikan akses pendidikan berkualitas yang mampu menyinergikan kecerdasan intelektual dan kedalaman spiritual. Berawal dari visi sederhana seorang tokoh ulama indonesia kh.aj.mustofa,yang peduli terhadap masa depan generasi muda, sekolah ini tumbuh dari langkah-langkah kecil yang penuh perjuangan. Melalui komitmen kuat dari para pendiri, dukungan guru-guru yang berdedikasi, serta kepercayaan penuh dari masyarakat, Nurul Hidayah kini terus berkembang menjadi institusi yang tidak hanya mengajarkan ilmu pengetahuan, tetapi juga membentuk karakter. beliau percaya bahwa setiap anak adalah amanah, dan sejarah kami adalah perjalanan panjang dalam menjaga amanah tersebut untuk generasi yang lebih baik."</p>
        </div>
    </section>
</div>

<script>
    // Script Sederhana untuk deteksi scroll agar animasi jalan
    const observerOptions = { threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>

</body>
</html>